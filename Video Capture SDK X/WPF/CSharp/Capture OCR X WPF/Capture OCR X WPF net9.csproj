<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFrameworks>net9.0-windows</TargetFrameworks>
    <RootNamespace>Capture_OCR_X_WPF</RootNamespace>
    <PlatformTarget>x64</PlatformTarget>
    <ApplicationIcon>visioforge_main_icon.ico</ApplicationIcon>
    <UseWPF>true</UseWPF>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="visioforge_main_icon.ico" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="VisioForge.CrossPlatform.Core.Windows.x64" Version="2026.4.29" />
    <PackageReference Include="VisioForge.CrossPlatform.Libav.Windows.x64.UPX" Version="2026.4.29" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="VisioForge.DotNet.VideoCapture" Version="2026.7.6" />
    <PackageReference Include="VisioForge.DotNet.Core.AI" Version="2026.7.6" />
  </ItemGroup>
  <ItemGroup>
    <!-- Apache-2.0 PP-OCRv5 mobile models (detection, angle classification, recognition) + Latin dictionary,
         shipped next to the executable. Models are NOT in the NuGet package. -->
    <None Update="ch_PP-OCRv5_mobile_det.onnx">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="ch_ppocr_mobile_v2.0_cls_infer.onnx">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="latin_PP-OCRv5_rec_mobile_infer.onnx">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="ppocrv5_latin_dict.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>