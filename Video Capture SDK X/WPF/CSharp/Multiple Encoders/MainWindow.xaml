<Window x:Class="Multiple_Encoders.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Multiple_Encoders"
        xmlns:wpf="clr-namespace:VisioForge.Core.UI.WPF;assembly=VisioForge.Core"
        mc:Ignorable="d"
        Title="Multiple Encoders Demo - Video Capture SDK .Net"
        Height="1140" Width="1280"
        Icon="visioforge_main_icon.ico"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="PipelineLabel" TargetType="Label">
            <Setter Property="Padding" Value="0,2,0,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="PipelineCombo" TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="Height" Value="22"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 2x2 grid of pipeline panels -->
        <Grid Grid.Row="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Pipeline 1 -->
            <GroupBox Grid.Row="0" Grid.Column="0" Header="Pipeline 1" Margin="2">
                <StackPanel Orientation="Vertical" Margin="6">
                    <wpf:VideoView x:Name="videoView1" Width="320" Height="180" HorizontalAlignment="Left" Background="Black"/>
                    <Label Content="Video device" Style="{StaticResource PipelineLabel}"/>
                    <ComboBox x:Name="cbVideoDevice1" Tag="0" Style="{StaticResource PipelineCombo}" SelectionChanged="cbVideoDevice_SelectionChanged"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <Label Content="Video format" Style="{StaticResource PipelineLabel}"/>
                            <ComboBox x:Name="cbVideoFormat1" Tag="0" Style="{StaticResource PipelineCombo}" Margin="0,0,5,2" SelectionChanged="cbVideoFormat_SelectionChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Vertical">
                            <Label Content="Frame rate" Style="{StaticResource PipelineLabel}"/>
                            <ComboBox x:Name="cbVideoFrameRate1" Tag="0" Style="{StaticResource PipelineCombo}"/>
                        </StackPanel>
                    </Grid>
                    <Label Content="Audio device" Style="{StaticResource PipelineLabel}"/>
                    <ComboBox x:Name="cbAudioDevice1" Tag="0" Style="{StaticResource PipelineCombo}" SelectionChanged="cbAudioDevice_SelectionChanged"/>
                    <Label Content="Audio format" Style="{StaticResource PipelineLabel}"/>
                    <ComboBox x:Name="cbAudioFormat1" Tag="0" Style="{StaticResource PipelineCombo}"/>
                    <CheckBox x:Name="cbRecordAudio1" Content="Record audio" Margin="0,4,0,4" IsChecked="True"/>
                    <Label Content="Video encoder" Style="{StaticResource PipelineLabel}"/>
                    <ComboBox x:Name="cbVideoEncoder1" Tag="0" Style="{StaticResource PipelineCombo}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="Start" Width="65" Height="24" Tag="0" Click="btStart_Click"/>
                        <Button Content="Stop" Width="65" Height="24" Margin="6,0,0,0" Tag="0" Click="btStop_Click"/>
                        <TextBlock x:Name="lbStatus1" Text="Idle" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Pipeline 2 -->
            <GroupBox Grid.Row="0" Grid.Column="1" Header="Pipeline 2" Margin="2">
                <StackPanel Orientation="Vertical" Margin="6">
                    <wpf:VideoView x:Name="videoView2" Width="320" Height="180" HorizontalAlignment="Left" Background="Black"/>
                    <Label Content="Video device" Style="{StaticResource PipelineLabel}"/>
                    <ComboBox x:Name="cbVideoDevice2" Tag="1" Style="{StaticResource PipelineCombo}" SelectionChanged="cbVideoDevice_SelectionChanged"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <Label Content="Video format" Style="{StaticResource PipelineLabel}"/>
                            <ComboBox x:Name="cbVideoFormat2" Tag="1" Style="{StaticResource PipelineCombo}" Margin="0,0,5,2" SelectionChanged="cbVideoFormat_SelectionChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Vertical">
                            <Label Content="Frame rate" Style="{StaticResource PipelineLabel}"/>
                            <ComboBox x:Name="cbVideoFrameRate2" Tag="1" Style="{StaticResource PipelineCombo}"/>
                        </StackPanel>
                    </Grid>
                    <Label Content="Audio device" Style="{StaticResource PipelineLabel}"/>
                    <ComboBox x:Name="cbAudioDevice2" Tag="1" Style="{StaticResource PipelineCombo}" SelectionChanged="cbAudioDevice_SelectionChanged"/>
                    <Label Content="Audio format" Style="{StaticResource PipelineLabel}"/>
                    <ComboBox x:Name="cbAudioFormat2" Tag="1" Style="{StaticResource PipelineCombo}"/>
                    <CheckBox x:Name="cbRecordAudio2" Content="Record audio" Margin="0,4,0,4" IsChecked="True"/>
                    <Label Content="Video encoder" Style="{StaticResource PipelineLabel}"/>
                    <ComboBox x:Name="cbVideoEncoder2" Tag="1" Style="{StaticResource PipelineCombo}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="Start" Width="65" Height="24" Tag="1" Click="btStart_Click"/>
                        <Button Content="Stop" Width="65" Height="24" Margin="6,0,0,0" Tag="1" Click="btStop_Click"/>
                        <TextBlock x:Name="lbStatus2" Text="Idle" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Pipeline 3 -->
            <GroupBox Grid.Row="1" Grid.Column="0" Header="Pipeline 3" Margin="2">
                <StackPanel Orientation="Vertical" Margin="6">
                    <wpf:VideoView x:Name="videoView3" Width="320" Height="180" HorizontalAlignment="Left" Background="Black"/>
                    <Label Content="Video device" Style="{StaticResource PipelineLabel}"/>
                    <ComboBox x:Name="cbVideoDevice3" Tag="2" Style="{StaticResource PipelineCombo}" SelectionChanged="cbVideoDevice_SelectionChanged"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <Label Content="Video format" Style="{StaticResource PipelineLabel}"/>
                            <ComboBox x:Name="cbVideoFormat3" Tag="2" Style="{StaticResource PipelineCombo}" Margin="0,0,5,2" SelectionChanged="cbVideoFormat_SelectionChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Vertical">
                            <Label Content="Frame rate" Style="{StaticResource PipelineLabel}"/>
                            <ComboBox x:Name="cbVideoFrameRate3" Tag="2" Style="{StaticResource PipelineCombo}"/>
                        </StackPanel>
                    </Grid>
                    <Label Content="Audio device" Style="{StaticResource PipelineLabel}"/>
                    <ComboBox x:Name="cbAudioDevice3" Tag="2" Style="{StaticResource PipelineCombo}" SelectionChanged="cbAudioDevice_SelectionChanged"/>
                    <Label Content="Audio format" Style="{StaticResource PipelineLabel}"/>
                    <ComboBox x:Name="cbAudioFormat3" Tag="2" Style="{StaticResource PipelineCombo}"/>
                    <CheckBox x:Name="cbRecordAudio3" Content="Record audio" Margin="0,4,0,4" IsChecked="True"/>
                    <Label Content="Video encoder" Style="{StaticResource PipelineLabel}"/>
                    <ComboBox x:Name="cbVideoEncoder3" Tag="2" Style="{StaticResource PipelineCombo}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="Start" Width="65" Height="24" Tag="2" Click="btStart_Click"/>
                        <Button Content="Stop" Width="65" Height="24" Margin="6,0,0,0" Tag="2" Click="btStop_Click"/>
                        <TextBlock x:Name="lbStatus3" Text="Idle" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Pipeline 4 -->
            <GroupBox Grid.Row="1" Grid.Column="1" Header="Pipeline 4" Margin="2">
                <StackPanel Orientation="Vertical" Margin="6">
                    <wpf:VideoView x:Name="videoView4" Width="320" Height="180" HorizontalAlignment="Left" Background="Black"/>
                    <Label Content="Video device" Style="{StaticResource PipelineLabel}"/>
                    <ComboBox x:Name="cbVideoDevice4" Tag="3" Style="{StaticResource PipelineCombo}" SelectionChanged="cbVideoDevice_SelectionChanged"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <Label Content="Video format" Style="{StaticResource PipelineLabel}"/>
                            <ComboBox x:Name="cbVideoFormat4" Tag="3" Style="{StaticResource PipelineCombo}" Margin="0,0,5,2" SelectionChanged="cbVideoFormat_SelectionChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Vertical">
                            <Label Content="Frame rate" Style="{StaticResource PipelineLabel}"/>
                            <ComboBox x:Name="cbVideoFrameRate4" Tag="3" Style="{StaticResource PipelineCombo}"/>
                        </StackPanel>
                    </Grid>
                    <Label Content="Audio device" Style="{StaticResource PipelineLabel}"/>
                    <ComboBox x:Name="cbAudioDevice4" Tag="3" Style="{StaticResource PipelineCombo}" SelectionChanged="cbAudioDevice_SelectionChanged"/>
                    <Label Content="Audio format" Style="{StaticResource PipelineLabel}"/>
                    <ComboBox x:Name="cbAudioFormat4" Tag="3" Style="{StaticResource PipelineCombo}"/>
                    <CheckBox x:Name="cbRecordAudio4" Content="Record audio" Margin="0,4,0,4" IsChecked="True"/>
                    <Label Content="Video encoder" Style="{StaticResource PipelineLabel}"/>
                    <ComboBox x:Name="cbVideoEncoder4" Tag="3" Style="{StaticResource PipelineCombo}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="Start" Width="65" Height="24" Tag="3" Click="btStart_Click"/>
                        <Button Content="Stop" Width="65" Height="24" Margin="6,0,0,0" Tag="3" Click="btStop_Click"/>
                        <TextBlock x:Name="lbStatus4" Text="Idle" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- Common bottom: output folder + log + start/stop all -->
        <Grid Grid.Row="1" Margin="12,0,12,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Output folder:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="edOutputFolder" Height="23" VerticalAlignment="Center" Margin="6,0,6,0"/>
                <Button Grid.Column="2" x:Name="btSelectOutputFolder" Content="..." Width="28" Height="23" Click="btSelectOutputFolder_Click"/>
                <Button Grid.Column="3" Content="Start all" Width="80" Height="23" Margin="12,0,0,0" Click="btStartAll_Click"/>
                <Button Grid.Column="4" Content="Stop all" Width="80" Height="23" Margin="6,0,0,0" Click="btStopAll_Click"/>
            </Grid>

            <TextBox Grid.Row="1" x:Name="mmLog" Height="80" Margin="0,8,0,0" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" IsReadOnly="True" FontFamily="Consolas" FontSize="11"/>
        </Grid>
    </Grid>
</Window>
