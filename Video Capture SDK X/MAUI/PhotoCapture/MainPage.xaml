<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PhotoCapture.MainPage" Loaded="ContentPage_Loaded" Unloaded="ContentPage_Unloaded">

    <ScrollView>
        <!--WidthRequest="1280" HeightRequest="720"-->
        <Grid x:Name="rootGrid" RowDefinitions="*,Auto" >

            <!-- PhotoCaptureView is added programmatically in code-behind, not in XAML.
                 The SDK type VisioForge.Core.UI.MAUI.PhotoCaptureView does not exist on
                 net10.0-maccatalyst (#if (__IOS__ && !__MACCATALYST__) || __ANDROID__ || WINDOWS),
                 so a static XAML reference would break XAML codegen on macCatalyst. -->

            <StackLayout Grid.Row="1" x:Name="pnMain" Orientation="Vertical" HorizontalOptions="Fill" Background="#1e1e1e">
                <StackLayout
                    Orientation="Horizontal"
                    HorizontalOptions="Center"
                    Margin="5, 0, 5, 0">

                    <Button
                        x:Name="btCamera"
                        Text="SWITCH CAMERA"
                        Margin="5"
                        Clicked="btCamera_Clicked"
                        MinimumWidthRequest="100" />

                    <Button
                        x:Name="btPhoto"
                        Text="SAVE PHOTO"
                        Margin="5"
                        Clicked="btPhoto_Clicked"
                        MinimumWidthRequest="100" />
                </StackLayout>
            </StackLayout>
        </Grid>
    </ScrollView>

</ContentPage>
