<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFrameworks>net6.0-windows</TargetFrameworks>
    <RootNamespace>youtube_player_x</RootNamespace>
    <PlatformTarget>x64</PlatformTarget>
    <ApplicationIcon>visioforge_main_icon.ico</ApplicationIcon>
    <UseWPF>true</UseWPF>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <AnalysisLevel>latest</AnalysisLevel>
    <NoWarn>S2325</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="visioforge_main_icon.ico" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="VisioForge.CrossPlatform.Core.Windows.x64" Version="2026.3.12" />
    <PackageReference Include="VisioForge.CrossPlatform.Libav.Windows.x64.UPX" Version="2026.3.12" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="VisioForge.DotNet.VideoCapture" Version="2026.4.22" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Ytdlp.NET" Version="3.0.3" />
    <PackageReference Include="ManuHub.Ytdlp" Version="6.3.17" />
    <PackageReference Include="ManuHub.Deno" Version="2.7.1" />
  </ItemGroup>
</Project>