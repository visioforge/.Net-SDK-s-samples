<Window x:Class="Player_OCR_X_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:WPF="clr-namespace:VisioForge.Core.UI.WPF;assembly=VisioForge.Core"
        Title="Player OCR (MediaPlayerCoreX)" Height="640" Width="1040"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <WPF:VideoView x:Name="VideoView1" Grid.Column="0" Margin="0,0,8,0" />

        <DockPanel Grid.Column="1">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="Media file" FontWeight="Bold" />
                <DockPanel Margin="0,2,0,8">
                    <Button x:Name="btSelectFile" DockPanel.Dock="Right" Content="..." Width="32" Click="btSelectFile_Click" />
                    <TextBox x:Name="edFile" />
                </DockPanel>

                <TextBlock Text="OCR options" FontWeight="Bold" Margin="0,4,0,2" />
                <CheckBox x:Name="cbUseAngle" Content="Use angle classifier (0/180°)" IsChecked="True" Margin="0,2,0,4" />
                <CheckBox x:Name="cbDrawResults" Content="Draw recognized text on video" IsChecked="True" Margin="0,0,0,6" />

                <DockPanel Margin="0,0,0,8">
                    <TextBlock DockPanel.Dock="Left" Text="Run OCR every N+1 frames (skip)" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox x:Name="edFramesToSkip" Text="3" Width="50" HorizontalAlignment="Left" />
                </DockPanel>

                <TextBlock Text="Apache-2.0 PP-OCRv5 mobile models ship with this demo." Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,8" />

                <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                    <Button x:Name="btStart" Content="Start" Width="90" Click="btStart_Click" />
                    <Button x:Name="btStop" Content="Stop" Width="90" Margin="8,0,0,0" IsEnabled="False" Click="btStop_Click" />
                </StackPanel>

                <TextBlock Text="Recognized text" FontWeight="Bold" />
            </StackPanel>

            <TextBox x:Name="mmLog" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap" FontFamily="Consolas" FontSize="11" />
        </DockPanel>
    </Grid>
</Window>
