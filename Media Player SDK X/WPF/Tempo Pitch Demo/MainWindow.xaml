<Window x:Class="Tempo_Pitch_Demo_X.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tempo_Pitch_Demo_X"
        xmlns:vf="clr-namespace:VisioForge.Core.UI.WPF;assembly=VisioForge.Core"
        mc:Ignorable="d"
        Title="Media Player SDK X .Net - Tempo / Pitch Demo (WPF)"
        Width="960" Height="780"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- main video -->
            <RowDefinition Height="Auto" />
            <!-- additional audio input -->
            <RowDefinition Height="Auto" />
            <!-- mix list + remove -->
            <RowDefinition Height="Auto" />
            <!-- audio output + volume -->
            <RowDefinition Height="Auto" />
            <!-- seek + time -->
            <RowDefinition Height="Auto" />
            <!-- tempo -->
            <RowDefinition Height="Auto" />
            <!-- pitch -->
            <RowDefinition Height="Auto" />
            <!-- status -->
            <RowDefinition Height="*" />
            <!-- video view -->
            <RowDefinition Height="Auto" />
            <!-- footer -->
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Video file:" VerticalAlignment="Center" Width="120" />
            <TextBox x:Name="textBoxVideoFile" Width="540" Height="24" />
            <Button x:Name="buttonBrowseVideo" Content="..." Width="30" Height="24" Margin="4,0,0,0" Click="buttonBrowseVideo_Click" />
            <Button x:Name="buttonPlay" Content="Play" Width="70" Height="24" Margin="10,0,0,0" Click="buttonPlay_Click" />
            <Button x:Name="buttonStop" Content="Stop" Width="70" Height="24" Margin="6,0,0,0" Click="buttonStop_Click" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Additional audio:" VerticalAlignment="Center" Width="120" />
            <TextBox x:Name="textBoxAudioFile" Width="540" Height="24" />
            <Button x:Name="buttonBrowseAudio" Content="..." Width="30" Height="24" Margin="4,0,0,0" Click="buttonBrowseAudio_Click" />
            <Button x:Name="buttonAudioAdd" Content="+ Add" Width="70" Height="24" Margin="10,0,0,0" Click="buttonAudioAdd_Click" />
            <Button x:Name="buttonAudioClear" Content="Clear" Width="70" Height="24" Margin="6,0,0,0" Click="buttonAudioClear_Click" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Mix:" VerticalAlignment="Top" Margin="0,4,0,0" />
            <ListBox x:Name="listAudioStreams" Grid.Column="1" Height="80" SelectionMode="Single" />
            <Button x:Name="buttonAudioRemove" Grid.Column="2" Content="- Remove" Width="80" Height="24"
                    VerticalAlignment="Top" Margin="6,0,0,0" Click="buttonAudioRemove_Click" />
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Audio output:" VerticalAlignment="Center" Width="120" />
            <ComboBox x:Name="cbAudioOutput" Width="300" Height="24" />
            <TextBlock Text="Volume:" VerticalAlignment="Center" Margin="20,0,0,0" />
            <Slider x:Name="sliderVolume" Width="200" Minimum="0" Maximum="100" Value="80"
                    VerticalAlignment="Center" Margin="8,0,0,0"
                    ValueChanged="sliderVolume_ValueChanged" />
            <TextBlock x:Name="lblVolume" VerticalAlignment="Center" Margin="8,0,0,0" Text="80%" Width="40" />
        </StackPanel>

        <DockPanel Grid.Row="4" Margin="0,0,0,6" LastChildFill="True">
            <TextBlock Text="Seek:" VerticalAlignment="Center" Width="120" DockPanel.Dock="Left" />
            <TextBlock x:Name="lblTime" VerticalAlignment="Center" Margin="8,0,0,0" DockPanel.Dock="Right"
                       Text="00:00:00 / 00:00:00" Width="140" TextAlignment="Right" />
            <Slider x:Name="sliderSeek" Minimum="0" Maximum="0" Value="0" VerticalAlignment="Center"
                    PreviewMouseDown="sliderSeek_PreviewMouseDown"
                    PreviewMouseUp="sliderSeek_PreviewMouseUp"
                    LostMouseCapture="sliderSeek_LostMouseCapture"
                    ValueChanged="sliderSeek_ValueChanged" />
        </DockPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Tempo:" VerticalAlignment="Center" Width="120" />
            <Button x:Name="buttonTempoMin" Content="-" Width="40" Height="24" Click="buttonTempoMin_Click" />
            <Button x:Name="buttonTempoNormal" Content="Normal" Width="80" Height="24" Margin="4,0,0,0" Click="buttonTempoNormal_Click" />
            <Button x:Name="buttonTempoPlus" Content="+" Width="40" Height="24" Margin="4,0,0,0" Click="buttonTempoPlus_Click" />
            <TextBlock x:Name="lblTempo" VerticalAlignment="Center" Margin="10,0,0,0" Text="1000" Width="60" />
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Pitch:" VerticalAlignment="Center" Width="120" />
            <Button x:Name="buttonPitchMin" Content="-" Width="40" Height="24" Click="buttonPitchMin_Click" />
            <Button x:Name="buttonPitchNormal" Content="Normal" Width="80" Height="24" Margin="4,0,0,0" Click="buttonPitchNormal_Click" />
            <Button x:Name="buttonPitchPlus" Content="+" Width="40" Height="24" Margin="4,0,0,0" Click="buttonPitchPlus_Click" />
            <TextBlock x:Name="lblPitch" VerticalAlignment="Center" Margin="10,0,0,0" Text="1000" Width="60" />
        </StackPanel>

        <TextBlock x:Name="lblStatus" Grid.Row="7" Margin="0,0,0,6" TextWrapping="Wrap" />

        <vf:VideoView x:Name="VideoView1" Grid.Row="8" />

        <TextBlock Grid.Row="9" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="Gray"
                   Text="Plays the main video file (audio optional) and mixes any number of additional audio files via Audio_AdditionalStreams_Add. Tempo and Pitch are applied to the mixed output so they affect every stream at once." />
    </Grid>
</Window>
