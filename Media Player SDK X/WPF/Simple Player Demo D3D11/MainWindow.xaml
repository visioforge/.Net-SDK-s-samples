<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Simple_Player_Demo_D3D11_X"
        xmlns:WPF="clr-namespace:VisioForge.Core.UI.WPF;assembly=VisioForge.Core"
        x:Class="Simple_Player_Demo_D3D11_X.MainWindow"
        mc:Ignorable="d"
        Title="Media Player SDK X (MediaPlayerCoreX) — D3D11 Composable Renderer demo"
        Height="420" Width="640" Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid>
        <Label Content="File name" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="edFilename" HorizontalAlignment="Left" Margin="10,36,0,0" TextWrapping="Wrap" Text="C:\samples\!video.mp4" VerticalAlignment="Top" Width="285"/>
        <Button x:Name="btSelectFile" Content="..." HorizontalAlignment="Left" Margin="300,35,0,0" VerticalAlignment="Top" Width="20" Height="20" Click="btSelectFile_Click"/>

        <!-- Video preview with WPF overlay. Composes correctly because the GPU
             texture is exposed to WPF as a regular D3DImage source. -->
        <Grid Margin="10,60,320,75">
            <WPF:VideoView x:Name="VideoView1"/>
            <Border x:Name="OverlayBanner" Background="#88000000" CornerRadius="8"
                    VerticalAlignment="Top" HorizontalAlignment="Left"
                    Margin="8,8,0,0" Padding="10,6">
                <TextBlock Text="WPF overlay on top of GPU video (X engine)"
                           Foreground="White" FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <CheckBox x:Name="cbDebugMode" Content="Debug mode" HorizontalAlignment="Right" Margin="0,11,27,0" VerticalAlignment="Top"/>
        <Label Content="Log" HorizontalAlignment="Right" Margin="0,5,270,0" VerticalAlignment="Top"/>
        <TextBox x:Name="edLog" HorizontalAlignment="Right" Margin="0,35,27,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="270" Height="98"/>

        <Slider x:Name="tbTimeline" HorizontalAlignment="Left" Margin="10,0,0,47" VerticalAlignment="Bottom" Width="209" ValueChanged="tbTimeline_ValueChanged"/>
        <TextBlock x:Name="lbTime" HorizontalAlignment="Left" Margin="225,0,0,49" TextWrapping="Wrap" Text="00:00:00 | 00:00:00" VerticalAlignment="Bottom"/>
        <Button x:Name="btStart" Content="Start" HorizontalAlignment="Left" Margin="10,0,0,21" VerticalAlignment="Bottom" Width="53" Click="btStart_Click"/>
        <Button x:Name="btResume" Content="Resume" HorizontalAlignment="Left" Margin="68,0,0,21" VerticalAlignment="Bottom" Width="53" Click="btResume_Click"/>
        <Button x:Name="btPause" Content="Pause" HorizontalAlignment="Left" Margin="126,0,0,21" VerticalAlignment="Bottom" Width="53" Click="btPause_Click"/>
        <Button x:Name="btStop" Content="Stop" HorizontalAlignment="Left" Margin="184,0,0,21" VerticalAlignment="Bottom" Width="53" Click="btStop_Click"/>

        <StackPanel Orientation="Vertical" Margin="0,143,25,0" HorizontalAlignment="Right" VerticalAlignment="Top">
            <TextBlock Text="Audio output device" />
            <ComboBox x:Name="cbAudioOutput" Width="270" Margin="0,5,0,0" />

            <TextBlock Text="Volume" Margin="0,5,0,0"/>
            <Slider x:Name="tbVolume" Width="270" Maximum="100" Value="80" ValueChanged="tbVolume_ValueChanged" Margin="0,5,0,0"/>

            <CheckBox x:Name="cbRotate" Content="Rotate VideoView 10°" Margin="0,12,0,0" Checked="cbRotate_Checked" Unchecked="cbRotate_Checked"/>
            <CheckBox x:Name="cbOpacity" Content="VideoView opacity 70%" Margin="0,4,0,0" Checked="cbOpacity_Checked" Unchecked="cbOpacity_Checked"/>
            <CheckBox x:Name="cbLoop" Content="Loop" Margin="0,4,0,0" />
        </StackPanel>
    </Grid>
</Window>
