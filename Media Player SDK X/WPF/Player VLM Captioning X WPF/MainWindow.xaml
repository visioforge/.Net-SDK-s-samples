<Window x:Class="Player_VLM_Captioning_X_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:WPF="clr-namespace:VisioForge.Core.UI.WPF;assembly=VisioForge.Core"
        Title="Player VLM Captioning (MediaPlayerCoreX)" Height="720" Width="1160"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="420" />
        </Grid.ColumnDefinitions>

        <WPF:VideoView x:Name="VideoView1" Grid.Column="0" Margin="0,0,8,0" />

        <DockPanel Grid.Column="1">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="Media file" FontWeight="Bold" />
                <DockPanel Margin="0,2,0,8">
                    <Button x:Name="btSelectFile" DockPanel.Dock="Right" Content="..." Width="32" Click="btSelectFile_Click" />
                    <TextBox x:Name="edFile" />
                </DockPanel>

                <TextBlock Text="Florence-2 model folder" FontWeight="Bold" />
                <DockPanel Margin="0,2,0,4">
                    <Button x:Name="btSelectFolder" DockPanel.Dock="Right" Content="..." Width="32" Click="btSelectFolder_Click" />
                    <TextBox x:Name="edModelFolder" TextChanged="edModelFolder_TextChanged" />
                </DockPanel>
                <Button x:Name="btDownloadModels" Content="Download model files" HorizontalAlignment="Left" Width="200" Margin="0,0,0,6" Click="btDownloadModels_Click" />

                <StackPanel x:Name="pnlDownload" Orientation="Vertical" Margin="0,0,0,8" Visibility="Collapsed">
                    <TextBlock x:Name="lbDownloadStatus" TextTrimming="CharacterEllipsis" />
                    <ProgressBar x:Name="pbDownload" Height="16" Margin="0,4,0,0" Minimum="0" Maximum="100" />
                </StackPanel>

                <TextBlock Text="Task" FontWeight="Bold" />
                <ComboBox x:Name="cbTask" Margin="0,2,0,8" SelectionChanged="cbTask_SelectionChanged" />

                <TextBlock Text="Text input (Phrase grounding caption)" />
                <TextBox x:Name="edTextInput" Margin="0,2,0,8" IsEnabled="False" TextChanged="edTextInput_TextChanged" />

                <DockPanel Margin="0,0,0,6">
                    <TextBlock DockPanel.Dock="Left" Text="Processing interval (s)" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox x:Name="edInterval" Text="1.0" Width="60" HorizontalAlignment="Left" />
                </DockPanel>
                <DockPanel Margin="0,0,0,6">
                    <TextBlock DockPanel.Dock="Left" Text="Max new tokens" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox x:Name="edMaxTokens" Text="256" Width="60" HorizontalAlignment="Left" />
                </DockPanel>
                <CheckBox x:Name="cbDrawResults" Content="Draw results on video" IsChecked="True" Margin="0,0,0,8" />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="btStart" Content="Start" Width="90" Click="btStart_Click" />
                    <Button x:Name="btStop" Content="Stop" Width="90" Margin="8,0,0,0" IsEnabled="False" Click="btStop_Click" />
                    <TextBlock x:Name="lbStatus" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="DarkSlateGray" Text="Provider: -" />
                </StackPanel>

                <TextBlock Text="Results" FontWeight="Bold" />
            </StackPanel>

            <DataGrid x:Name="dgResults" Margin="0,4,0,0" AutoGenerateColumns="False"
                      IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="70" />
                    <DataGridTextColumn Header="Task" Binding="{Binding Task}" Width="130" />
                    <DataGridTextColumn Header="Text" Binding="{Binding Text}" Width="*" />
                    <DataGridTextColumn Header="ms" Binding="{Binding InferenceTimeMs}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</Window>
