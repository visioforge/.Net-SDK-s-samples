<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Player_OCR_X.MainPage"
             xmlns:my="clr-namespace:VisioForge.Core.UI.MAUI;assembly=VisioForge.Core.UI.MAUI">

    <Grid RowSpacing="0" RowDefinitions="*,Auto">

        <my:VideoView Grid.Row="0"
            HorizontalOptions="FillAndExpand"
            VerticalOptions="FillAndExpand"
            x:Name="videoView"
            Background="Black"/>

        <!-- Live OCR summary, overlaid on the video. -->
        <Label Grid.Row="0" x:Name="lbStatus"
            Text="Open a file, then START."
            Margin="12" Padding="8,4" BackgroundColor="#90000000" TextColor="White"
            FontSize="13" HorizontalOptions="Start" VerticalOptions="Start" />

        <VerticalStackLayout Grid.Row="1" Spacing="6" Background="#1e1e1e" Padding="12,8,12,12">

            <Button x:Name="btFile" Text="OPEN FILE" Clicked="btFile_Clicked" />

            <Button x:Name="btStartStop" Text="START" Clicked="btStartStop_Clicked"
                BackgroundColor="#4CAF50" />

        </VerticalStackLayout>
    </Grid>
</ContentPage>
