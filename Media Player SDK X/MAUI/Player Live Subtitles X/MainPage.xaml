<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Player_Live_Subtitles_X.MainPage"
             xmlns:my="clr-namespace:VisioForge.Core.UI.MAUI;assembly=VisioForge.Core.UI.MAUI">

    <Grid RowSpacing="0" RowDefinitions="*,Auto">

        <my:VideoView Grid.Row="0"
            HorizontalOptions="FillAndExpand"
            VerticalOptions="FillAndExpand"
            x:Name="videoView"
            Background="Black"/>

        <!-- Live subtitle, overlaid at the bottom of the video. -->
        <Label Grid.Row="0" x:Name="lbSubtitle"
            Text=""
            Margin="16" Padding="10,6" BackgroundColor="#A0000000" TextColor="White"
            FontSize="16" HorizontalTextAlignment="Center"
            HorizontalOptions="Center" VerticalOptions="End" />

        <VerticalStackLayout Grid.Row="1" Spacing="6" Background="#1e1e1e" Padding="12,8,12,12">

            <Label x:Name="lbStatus" Text="Choose a Whisper model and a media file, then START."
                TextColor="#B0FFFFFF" FontSize="12" LineBreakMode="TailTruncation" />

            <!-- Model selection: pick a preset to download, or "Custom file…" to browse for a .bin. -->
            <Picker x:Name="pkModel" Title="Whisper model" TitleColor="#B0FFFFFF" TextColor="White"
                SelectedIndexChanged="pkModel_SelectedIndexChanged" />

            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <ProgressBar Grid.Column="0" x:Name="pbDownload" Progress="0" ProgressColor="#4CAF50"
                    IsVisible="False" VerticalOptions="Center" />
                <Button Grid.Column="1" x:Name="btDownloadModel" Text="Download" Clicked="btDownloadModel_Clicked"
                    IsVisible="False" />
                <Button Grid.Column="2" x:Name="btBrowseModel" Text="Browse…" Clicked="btBrowseModel_Clicked"
                    IsVisible="False" />
            </Grid>

            <Button x:Name="btFile" Text="OPEN FILE" Clicked="btFile_Clicked" />

            <Button x:Name="btStartStop" Text="START" Clicked="btStartStop_Clicked"
                BackgroundColor="#4CAF50" />

        </VerticalStackLayout>
    </Grid>
</ContentPage>
