<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:output_gif" x:Class="output_gif.MainWindow"
        mc:Ignorable="d"
        Title="Video Edit SDK X .Net - Render to animated GIF" Height="220" Width="430" Loaded="Window_Loaded" Closing="Window_Closing" Icon="visioforge_main_icon.ico">
    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,16,16,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Source video file" Width="120" />
                <TextBox Text="c:\vf\Test-VisioForge.mp4" VerticalAlignment="Center" Margin="0,0,10,0" Width="230" x:Name="edSourceVideoFile" />
                <Button x:Name="btSelectVideo" Content="..." Click="btSelectVideo_Click" Width="20" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Output GIF file" Width="120" />
                <TextBox Text="c:\vf\output.gif" VerticalAlignment="Center" Margin="0,0,10,0" Width="230" x:Name="edOutputFile"/>
                <Button x:Name="btSelectOutput" Content="..." Click="btSelectOutput_Click" Width="20" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Speed (1..30)" Width="120" />
                <TextBox Text="10" VerticalAlignment="Center" Width="60" x:Name="edSpeed"/>
                <TextBlock Text="Repeat (-1 = infinite)" Width="140" Margin="20,0,0,0" />
                <TextBox Text="0" VerticalAlignment="Center" Width="60" x:Name="edRepeat"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" >
                <Button x:Name="btStart" Content="Start" Width="50" Click="btStart_Click" Margin="0,0,10,0"/>
                <Button x:Name="btStop" Content="Stop" Width="50" Click="btStop_Click" Margin="0,0,10,0"/>
            </StackPanel>

        </StackPanel>

    </Grid>
</Window>
