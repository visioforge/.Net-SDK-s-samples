<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <VisioForge.Core.UI.Android.VideoViewTX
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:id="@+id/videoView" />

    <LinearLayout
        android:id="@+id/panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/panel_background"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <Spinner
                android:id="@+id/spSources"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btRefresh"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/btn_small"
                android:src="@drawable/ic_refresh"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:contentDescription="@string/cd_refresh_sources" />
        </LinearLayout>

        <TextView
            android:id="@+id/lbStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_tap_refresh"
            android:textColor="#B0FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btStart"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/btn_circle"
                android:src="@drawable/ic_play"
                android:scaleType="centerInside"
                android:padding="14dp"
                android:contentDescription="@string/cd_connect" />

            <ImageButton
                android:id="@+id/btStop"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/btn_circle"
                android:src="@drawable/ic_stop"
                android:scaleType="centerInside"
                android:padding="14dp"
                android:contentDescription="@string/cd_disconnect" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
