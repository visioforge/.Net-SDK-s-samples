<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>
    <OutputType>Exe</OutputType>
    <Nullable>disable</Nullable>
    <ImplicitUsings>true</ImplicitUsings>
    <SupportedOSPlatformVersion>13.0</SupportedOSPlatformVersion>
    <ProvisioningType>automatic</ProvisioningType>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <CodesignKey>iPhone Developer</CodesignKey>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <CreatePackage>false</CreatePackage>
    <WarningLevel>4</WarningLevel>
    <MtouchLink>SdkOnly</MtouchLink>
    <MtouchInterpreter>VisioForge.Core.dll</MtouchInterpreter>
    <MtouchNoSymbolStrip>True</MtouchNoSymbolStrip>
    <MtouchDebug>True</MtouchDebug>
    <CodesignKey>iPhone Developer</CodesignKey>
    <DeviceSpecificBuild>true</DeviceSpecificBuild>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <CreatePackage>false</CreatePackage>
    <MtouchNoSymbolStrip>True</MtouchNoSymbolStrip>
    <MtouchDebug>True</MtouchDebug>
    <MtouchInterpreter>VisioForge.Core.dll</MtouchInterpreter>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="VisioForge.DotNet.MediaBlocks" Version="2026.5.13" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="VisioForge.CrossPlatform.Core.iOS" Version="2025.0.16" />
  </ItemGroup>
  <!-- Pin SkiaSharp.NativeAssets.iOS to the version required transitively by
       VisioForge.DotNet.MediaBlocks -> SkiaSharp 3.119.3-preview.1.1.
       No stable >= 3.119.3 has shipped yet; using the older stable 3.119.2
       triggers NU1605 (package downgrade). Customers building for the iOS
       simulator with this preview may still hit the missing-simulator-slices
       linker error — ScreenCapture is intended for real devices. -->
  <ItemGroup>
    <PackageReference Include="SkiaSharp.NativeAssets.iOS" Version="3.119.3-preview.1.1" />
  </ItemGroup>
</Project>