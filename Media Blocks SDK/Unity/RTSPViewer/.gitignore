# Unity project artifacts (regenerated locally)
UnityProject/[Ll]ibrary/
UnityProject/[Tt]emp/
UnityProject/[Oo]bj/
UnityProject/[Bb]uild/
UnityProject/[Bb]uilds/
UnityProject/[Ll]ogs/
UnityProject/[Uu]ser[Ss]ettings/
UnityProject/[Mm]emoryCaptures/

# Unity 6 / Asset Store
UnityProject/[Aa]ssets/AssetStoreTools*

# Visual Studio / Rider
UnityProject/*.csproj
UnityProject/*.sln
UnityProject/.vs/
UnityProject/.idea/

# Deployed binaries (regenerated by deploy-unity-natives.ps1 / deploy-unity-managed.ps1)
UnityProject/Assets/Plugins/x64/
UnityProject/Assets/Plugins/x64.meta
UnityProject/Assets/Plugins/x86_64/
UnityProject/Assets/Plugins/x86_64.meta
UnityProject/Assets/Plugins/*.dll
UnityProject/Assets/Plugins/*.dll.meta
UnityProject/Assets/Plugins.meta
UnityProject/Assets/StreamingAssets/VisioForge/
UnityProject/Assets/StreamingAssets/VisioForge.meta
UnityProject/Assets/StreamingAssets.meta

# Crash reports
UnityProject/sysinfo.txt
UnityProject/crashlytics-build.properties

# Unity native plugin meta noise
*.pidb
*.booproj

# The repo-root .gitignore has a global "*.meta" rule. Unity REQUIRES .meta files for
# source assets to be tracked (they carry the stable GUIDs the scene uses to reference
# the script). Re-include the source .meta files here. Deployed binaries under
# Plugins/x64 and StreamingAssets/VisioForge stay excluded (their whole dirs are ignored
# above, so these negations don't reach them).
!UnityProject/Assets/Scripts.meta
!UnityProject/Assets/Scenes.meta
!UnityProject/Assets/Scripts/**/*.meta
!UnityProject/Assets/Scenes/**/*.meta
