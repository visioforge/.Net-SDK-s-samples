<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Simple_Player_MVVM.ViewModels"
			 xmlns:avalonia="clr-namespace:VisioForge.Core.UI.Avalonia;assembly=VisioForge.Core.UI.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Simple_Player_MVVM.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

	<Grid RowDefinitions="*,Auto" ColumnDefinitions="*">
		<!-- Video View -->
		<Border Grid.Row="0" Background="Black" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
			<avalonia:VideoView x:Name="videoView1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#0C0C0C" />
		</Border>

		<!-- Controls -->
		<StackPanel Grid.Row="1" Background="#1e1e1e" Orientation="Vertical">

			<!-- Seek slider -->
			<Slider Name="slSeeking" Margin="12,8,12,0" MinHeight="48" Maximum="{Binding SeekingMaximum}" Value="{Binding SeekingValue}"/>

			<!-- Position / Duration -->
			<Grid Margin="12,0" ColumnDefinitions="Auto,*,Auto">
				<TextBlock Grid.Column="0" Text="{Binding Position}" Foreground="#B0FFFFFF" FontSize="12" VerticalAlignment="Center"/>
				<TextBlock Grid.Column="2" Text="{Binding Duration}" Foreground="#B0FFFFFF" FontSize="12" VerticalAlignment="Center"/>
			</Grid>

			<!-- Playback buttons -->
			<UniformGrid Columns="3" Margin="12,4,12,0">
				<Button Command="{Binding OpenFileCommand}" Content="OPEN" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,4,0"/>
				<Button Command="{Binding PlayPauseCommand}" Content="{Binding PlayPauseText}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="2,0"/>
				<Button Command="{Binding StopCommand}" Content="STOP" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="4,0,0,0"/>
			</UniformGrid>

			<!-- Volume + Speed -->
			<Grid Margin="12,4,12,8" ColumnDefinitions="Auto,*,Auto">
				<TextBlock Grid.Column="0" Text="Vol" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
				<Slider Grid.Column="1" Value="{Binding VolumeValue}" Minimum="0" Maximum="100" MinHeight="48" VerticalAlignment="Center"/>
				<Button Grid.Column="2" Command="{Binding SpeedCommand}" Content="{Binding SpeedText}" Margin="8,0,0,0" MinWidth="50" HorizontalContentAlignment="Center"/>
			</Grid>
		</StackPanel>

	</Grid>
</UserControl>
