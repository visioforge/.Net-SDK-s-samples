<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:my="clr-namespace:VisioForge.Core.UI.Avalonia;assembly=VisioForge.Core.UI.Avalonia"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="BarcodeReaderMB.MainWindow"
        Title="VisioForge Barcode Reader (Avalonia)" Width="900" Height="700">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Video View -->
        <my:VideoView Grid.Row="0" x:Name="videoView" Background="Black" />

        <!-- Control Panel -->
        <Border Grid.Row="1" Background="#1e1e1e" Padding="10">
            <StackPanel>
                <!-- Detection Status Panel -->
                <Border Background="#2d2d2d" Padding="15" Margin="0,0,0,10" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="LAST DETECTED BARCODE" 
                                   HorizontalAlignment="Center" 
                                   FontSize="12" 
                                   Foreground="#888"
                                   Margin="0,0,0,10"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                            <TextBlock Text="Type: " Foreground="White" FontSize="14"/>
                            <TextBlock x:Name="lbBarcodeType" Text="-" Foreground="White" FontSize="14"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                            <TextBlock Text="Value: " Foreground="White" FontSize="16" FontWeight="Bold"/>
                            <TextBlock x:Name="lbBarcodeValue" Text="-" Foreground="#4CAF50" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                        
                        <TextBlock x:Name="lbDetectionCount" 
                                   Text="Detected: 0" 
                                   HorizontalAlignment="Center" 
                                   FontSize="12" 
                                   Foreground="#888"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Controls Grid -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Camera Selection -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="VIDEO SOURCE" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,0,0,5"
                                   Foreground="White"
                                   FontSize="12"/>
                        <ComboBox x:Name="cbVideoInput" 
                                  SelectionChanged="cbVideoInput_SelectionChanged"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Video Format -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="FORMAT" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,0,0,5"
                                   Foreground="White"
                                   FontSize="12"/>
                        <ComboBox x:Name="cbVideoFormat" 
                                  SelectionChanged="cbVideoFormat_SelectionChanged"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Control Buttons -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btStart" 
                                Content="START" 
                                Click="btStart_Click" 
                                Background="#4CAF50"
                                Foreground="White"
                                Width="100"
                                Margin="0,0,5,0"/>
                        <Button x:Name="btStop" 
                                Content="STOP" 
                                Click="btStop_Click"
                                Background="#f44336"
                                Foreground="White"
                                Width="100"
                                IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
