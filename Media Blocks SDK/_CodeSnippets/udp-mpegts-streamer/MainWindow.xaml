<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:udp_mpegts_streamer_mb"
        xmlns:WPF="clr-namespace:VisioForge.Core.UI.WPF;assembly=VisioForge.Core" x:Class="udp_mpegts_streamer_mb.MainWindow"
        mc:Ignorable="d"
        Title="Media Blocks SDK .Net - Screen source to UDP MPEG-TS output sample" Height="450" Width="800" Loaded="Window_Loaded" Closing="Window_Closing" Icon="visioforge_main_icon.ico">
    <Grid>
        <WPF:VideoView x:Name="videoView1" Margin="16,16,16,90"/>
        <Label Content="Host:" Target="{Binding ElementName=edHost}" HorizontalAlignment="Left" Margin="16,0,0,60" VerticalAlignment="Bottom"/>
        <TextBox x:Name="edHost" Text="localhost" HorizontalAlignment="Left" Margin="55,0,0,63" VerticalAlignment="Bottom" Width="120"/>
        <Label Content="Port:" Target="{Binding ElementName=edPort}" HorizontalAlignment="Left" Margin="185,0,0,60" VerticalAlignment="Bottom"/>
        <TextBox x:Name="edPort" Text="5004" HorizontalAlignment="Left" Margin="222,0,0,63" VerticalAlignment="Bottom" Width="60" TextChanged="edPort_TextChanged"/>
        <Button x:Name="btStart" Content="Start" HorizontalAlignment="Left" Margin="300,0,0,62" VerticalAlignment="Bottom" Width="50" Click="btStart_Click"/>
        <Button x:Name="btStop" Content="Stop" HorizontalAlignment="Left" Margin="355,0,0,62" VerticalAlignment="Bottom" Width="50" Click="btStop_Click"/>
        <TextBox x:Name="tbPlaybackInfo"
                 IsReadOnly="True" IsTabStop="False" BorderThickness="0" Background="Transparent"
                 TextWrapping="Wrap" HorizontalAlignment="Left" Margin="16,0,0,8" VerticalAlignment="Bottom" FontSize="11"/>
    </Grid>
</Window>
