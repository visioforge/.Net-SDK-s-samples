<Window x:Class="OCR_Text_Recognition_Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OCR_Text_Recognition_Demo" xmlns:wpf="clr-namespace:VisioForge.Core.UI.WPF;assembly=VisioForge.Core"
        mc:Ignorable="d"
        Title="Media Blocks SDK .Net - OCR Text Recognition Demo" Height="560" Width="920" Loaded="Window_Loaded" Closing="Window_Closing" Icon="visioforge_main_icon.ico">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="440" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <wpf:VideoView Grid.Column="1" x:Name="VideoView1" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="380" Margin="10,10,10,0" Width="450"/>

        <TabControl Grid.Column="0" Margin="10,10,0,10" VerticalAlignment="Stretch">
            <TabItem Header="Source">
                <StackPanel Orientation="Vertical" Margin="10,10,0,0">
                    <RadioButton Content="Webcam" x:Name="rbWebcam" IsChecked="True" Checked="rbSource_Checked" />
                    <RadioButton Content="Video file" x:Name="rbFile" Margin="0,5,0,0" Checked="rbSource_Checked" />
                    <RadioButton Content="RTSP / IP camera" x:Name="rbRTSP" Margin="0,5,0,0" Checked="rbSource_Checked" />

                    <StackPanel x:Name="pnlWebcam" Orientation="Vertical" Margin="0,10,0,0">
                        <Label Content="Video input device" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <ComboBox x:Name="cbVideoInput" HorizontalAlignment="Left" VerticalAlignment="Top" Width="400" SelectionChanged="cbVideoInput_SelectionChanged"/>
                        <Label Content="Video format and frame rate" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="cbVideoFormat" Width="310" SelectionChanged="cbVideoFormat_SelectionChanged"/>
                            <ComboBox x:Name="cbVideoFrameRate" Margin="10,0,0,0" Width="55"/>
                            <Label Content="fps" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="pnlFile" Orientation="Vertical" Margin="0,10,0,0" Visibility="Collapsed">
                        <Label Content="Video file" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="edVideoFile" Width="340" VerticalContentAlignment="Center"/>
                            <Button x:Name="btSelectVideoFile" Content="..." Width="40" Margin="10,0,0,0" Click="btSelectVideoFile_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="pnlRTSP" Orientation="Vertical" Margin="0,10,0,0" Visibility="Collapsed">
                        <Label Content="RTSP URL" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <TextBox x:Name="edRTSPURL" Width="400" VerticalContentAlignment="Center" Text="rtsp://"/>
                        <Label Content="Login" HorizontalAlignment="Left" Margin="0,5,0,0"/>
                        <TextBox x:Name="edRTSPLogin" Width="400" VerticalContentAlignment="Center"/>
                        <Label Content="Password" HorizontalAlignment="Left" Margin="0,5,0,0"/>
                        <PasswordBox x:Name="edRTSPPassword" Width="400"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="OCR">
                <StackPanel Orientation="Vertical" Margin="10,10,0,0">
                    <Label Content="Detection model (DBNet)" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="edDetModel" Width="340" VerticalContentAlignment="Center"/>
                        <Button Content="..." Width="40" Margin="10,0,0,0" Click="btSelectDet_Click"/>
                    </StackPanel>

                    <Label Content="Angle classifier model (optional)" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="edClsModel" Width="340" VerticalContentAlignment="Center"/>
                        <Button Content="..." Width="40" Margin="10,0,0,0" Click="btSelectCls_Click"/>
                    </StackPanel>

                    <Label Content="Recognition model (CRNN/SVTR)" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="edRecModel" Width="340" VerticalContentAlignment="Center"/>
                        <Button Content="..." Width="40" Margin="10,0,0,0" Click="btSelectRec_Click"/>
                    </StackPanel>

                    <Label Content="Character dictionary (.txt)" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="edDict" Width="340" VerticalContentAlignment="Center"/>
                        <Button Content="..." Width="40" Margin="10,0,0,0" Click="btSelectDict_Click"/>
                    </StackPanel>

                    <CheckBox x:Name="cbUseAngle" Content="Use angle classifier (0/180°)" IsChecked="True" Margin="0,10,0,0"/>
                    <CheckBox x:Name="cbDrawResults" Content="Draw recognized text on video" IsChecked="True" Margin="0,6,0,0"/>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Label Content="Run OCR every N+1 frames (skip)" Width="220"/>
                        <TextBox x:Name="edFramesToSkip" Text="3" Width="50" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <Label Content="Apache-2.0 PP-OCRv5 mobile models ship with this demo." Margin="0,10,0,0"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Recognized text">
                <ListBox x:Name="lbResults" Margin="10"/>
            </TabItem>

            <TabItem Header="Log">
                <TextBox x:Name="mmLog" Margin="10" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" IsReadOnly="True"/>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,400,0,0">
            <Button x:Name="btStart" Content="Start" Width="60" Click="btStart_Click"/>
            <Button x:Name="btStop" Content="Stop" Width="60" Margin="10,0,0,0" Click="btStop_Click" IsEnabled="False"/>
        </StackPanel>

        <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,400,10,0" Text="00:00:00" x:Name="lbTime"/>
    </Grid>
</Window>
