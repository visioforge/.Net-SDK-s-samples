<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SRT_Streamer_Demo"
        xmlns:WPF="clr-namespace:VisioForge.Core.UI.WPF;assembly=VisioForge.Core"
        x:Class="SRT_Streamer_Demo.MainWindow"
        mc:Ignorable="d"
        Title="Media Blocks SDK .Net - SRT Streamer Demo" Height="680" Width="1031" Loaded="Window_Loaded" Closing="Window_Closing" Icon="visioforge_main_icon.ico">
    <Grid>

        <WPF:VideoView x:Name="VideoView1" HorizontalAlignment="Left" Height="360" Margin="366,10,0,0" VerticalAlignment="Top" Width="640"/>

        <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left" VerticalAlignment="Top" Margin="366,383,0,0">
            <Button x:Name="btStart" Content="Start" Width="50" Click="btStart_Click"/>
            <Button x:Name="btStop" Content="Stop" Width="50" Margin="10,0,0,0" Click="btStop_Click"/>
            <TextBlock x:Name="lbTime" Text="00:00:00" Margin="15,0,0,0" />
        </StackPanel>

        <TextBox x:Name="mmLog" HorizontalAlignment="Left" Height="104" Margin="366,420,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="640" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>

        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0" Width="340">

            <RadioButton x:Name="rbCameraSource" IsChecked="true" Content="Camera source" />
            <StackPanel Orientation="Horizontal" Margin="10,10,0,0">
                <Label Content="Device" HorizontalAlignment="Left" Width="90"/>
                <ComboBox x:Name="cbVideoInput" HorizontalAlignment="Left" Width="230" VerticalContentAlignment="Center" SelectionChanged="cbVideoInput_SelectionChanged"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="10,10,0,0">
                <Label Content="Format" HorizontalAlignment="Left" Width="80"/>
                <ComboBox x:Name="cbVideoFormat" HorizontalAlignment="Left" Margin="10,0,0,0" Width="150" VerticalContentAlignment="Center" SelectionChanged="cbVideoFormat_SelectionChanged"/>

                <ComboBox x:Name="cbVideoFrameRate" HorizontalAlignment="Left" Margin="10,0,0,0" Width="50" VerticalContentAlignment="Center"/>
                <Label Content="fps" HorizontalAlignment="Left" />
            </StackPanel>

            <RadioButton x:Name="rbScreenSource" IsChecked="false" Margin="0,10,0,0" Content="Screen source" />

            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                <Label Content="Audio source" HorizontalAlignment="Left" Width="90" VerticalAlignment="Center"/>
                <ComboBox x:Name="cbAudioInput" HorizontalAlignment="Left" Margin="10,0,0,0" Width="230" VerticalContentAlignment="Center" SelectionChanged="cbAudioInput_SelectionChanged"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Label Content="Format" HorizontalAlignment="Left" Margin="10,0,0,0" Width="80"/>
                <ComboBox x:Name="cbAudioFormat" HorizontalAlignment="Left" Margin="10,0,0,0" Width="230" VerticalContentAlignment="Center"/>
            </StackPanel>

            <Separator Margin="0,15,0,0"/>

            <!-- SRT Settings -->
            <TextBlock Text="SRT Settings" FontWeight="Bold" Margin="0,10,0,5"/>

            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <Label Content="URI" Width="100"/>
                <TextBox x:Name="edSrtUri" Width="230" Text="srt://192.168.1.44:8890?streamid=publish:srt-demo" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <Label Content="Mode" Width="100"/>
                <ComboBox x:Name="cbSrtMode" Width="230" SelectedIndex="0" VerticalContentAlignment="Center">
                    <ComboBoxItem>Caller</ComboBoxItem>
                    <ComboBoxItem>Listener</ComboBoxItem>
                    <ComboBoxItem>Rendezvous</ComboBoxItem>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <Label Content="Latency (ms)" Width="100"/>
                <TextBox x:Name="edSrtLatency" Width="100" Text="750" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <Label Content="Muxer lat. (ms)" Width="100"/>
                <TextBox x:Name="edMuxerLatency" Width="100" Text="1000" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <CheckBox x:Name="cbAutoReconnect" Content="Auto reconnect" IsChecked="True" VerticalAlignment="Center" Margin="5,0,0,0"/>
                <CheckBox x:Name="cbWaitForConnection" Content="Wait for connection" IsChecked="False" VerticalAlignment="Center" Margin="15,0,0,0"/>
            </StackPanel>

            <!-- Encryption -->
            <TextBlock Text="Encryption" FontWeight="Bold" Margin="0,10,0,5"/>

            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <Label Content="Passphrase" Width="100"/>
                <TextBox x:Name="edPassphrase" Width="230" Text="" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <Label Content="Key length" Width="100"/>
                <ComboBox x:Name="cbKeyLength" Width="230" SelectedIndex="0" VerticalContentAlignment="Center">
                    <ComboBoxItem>None</ComboBoxItem>
                    <ComboBoxItem>16 bytes (128-bit)</ComboBoxItem>
                    <ComboBoxItem>24 bytes (192-bit)</ComboBoxItem>
                    <ComboBoxItem>32 bytes (256-bit)</ComboBoxItem>
                </ComboBox>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
