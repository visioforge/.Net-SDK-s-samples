<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFrameworks>net10.0-windows</TargetFrameworks>
    <RootNamespace>Live_Subtitles_Demo</RootNamespace>
    <UseWPF>true</UseWPF>
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>
  <ItemGroup>
    <!-- Whisper.net is used here for the optional model downloader (WhisperGgmlDownloader). -->
    <PackageReference Include="Whisper.net" Version="1.9.1" />
    <PackageReference Include="VisioForge.CrossPlatform.Core.Windows.x64" Version="2026.4.29" />
    <PackageReference Include="VisioForge.CrossPlatform.Libav.Windows.x64.UPX" Version="2026.4.29" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="VisioForge.DotNet.MediaBlocks" Version="2026.6.21" />
    <PackageReference Include="VisioForge.DotNet.Core.AI.Whisper" Version="2026.6.8" />
  </ItemGroup>
</Project>