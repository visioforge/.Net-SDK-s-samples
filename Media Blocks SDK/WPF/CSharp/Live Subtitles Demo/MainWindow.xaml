<Window x:Class="Live_Subtitles_Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Live_Subtitles_Demo" xmlns:wpf="clr-namespace:VisioForge.Core.UI.WPF;assembly=VisioForge.Core"
        mc:Ignorable="d"
        Title="Media Blocks SDK .Net - Live Subtitles Demo" Height="640" Width="960" Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="430" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <wpf:VideoView Grid.Column="1" x:Name="VideoView1" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="330" Margin="10,10,10,0"/>

        <Grid Grid.Column="1" Margin="10,345,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="90" />
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Content="Recognized speech" />
            <ListBox Grid.Row="1" x:Name="lbTranscript" />
            <Label Grid.Row="2" Content="Log" />
            <TextBox Grid.Row="3" x:Name="mmLog" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" AcceptsReturn="True"/>
        </Grid>

        <TabControl Grid.Column="0" Margin="10,10,0,50" VerticalAlignment="Stretch">
            <TabItem Header="Source">
                <StackPanel Orientation="Vertical" Margin="10,10,0,0">
                    <RadioButton Content="Webcam + Microphone" x:Name="rbWebcam" IsChecked="True" Checked="rbSource_Checked" />
                    <RadioButton Content="Media file (video + audio)" x:Name="rbFile" Margin="0,5,0,0" Checked="rbSource_Checked" />

                    <StackPanel x:Name="pnlWebcam" Orientation="Vertical" Margin="0,10,0,0">
                        <Label Content="Video input device" />
                        <ComboBox x:Name="cbVideoInput" Width="380" SelectionChanged="cbVideoInput_SelectionChanged"/>
                        <Label Content="Video format and frame rate" />
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="cbVideoFormat" Width="290" SelectionChanged="cbVideoFormat_SelectionChanged"/>
                            <ComboBox x:Name="cbVideoFrameRate" Margin="10,0,0,0" Width="55"/>
                            <Label Content="fps" />
                        </StackPanel>
                        <Label Content="Microphone" />
                        <ComboBox x:Name="cbAudioInput" Width="380"/>
                    </StackPanel>

                    <StackPanel x:Name="pnlFile" Orientation="Vertical" Margin="0,10,0,0" Visibility="Collapsed">
                        <Label Content="Media file" />
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="edVideoFile" Width="300" />
                            <Button x:Name="btSelectVideoFile" Content="Browse" Margin="10,0,0,0" Width="60" Click="btSelectVideoFile_Click"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="Models">
                <StackPanel Orientation="Vertical" Margin="10,10,0,0">
                    <Label Content="Whisper model" />
                    <ComboBox x:Name="cbModel" Width="380" SelectionChanged="cbModel_SelectionChanged"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBox x:Name="edModelFile" Width="240" />
                        <Button x:Name="btDownloadModel" Content="Download" Margin="10,0,0,0" Width="60" Click="btDownloadModel_Click"/>
                        <Button x:Name="btSelectModel" Content="Browse" Margin="5,0,0,0" Width="55" Click="btSelectModel_Click"/>
                    </StackPanel>

                    <CheckBox x:Name="cbEnableVad" Content="Enable Silero VAD (recommended)" IsChecked="True" Margin="0,12,0,0" />
                    <Label Content="Silero VAD model (silero_vad.onnx)" />
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="edVadFile" Width="240" />
                        <Button x:Name="btDownloadVad" Content="Download" Margin="10,0,0,0" Width="60" Click="btDownloadVad_Click"/>
                        <Button x:Name="btSelectVad" Content="Browse" Margin="5,0,0,0" Width="55" Click="btSelectVad_Click"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="Options">
                <StackPanel Orientation="Vertical" Margin="10,10,0,0">
                    <Label Content="Language (ISO code or 'auto')" />
                    <TextBox x:Name="edLanguage" Text="auto" Width="120" HorizontalAlignment="Left" />

                    <Label Content="Task" Margin="0,8,0,0" />
                    <ComboBox x:Name="cbTask" Width="200" HorizontalAlignment="Left" SelectedIndex="0">
                        <ComboBoxItem Content="Transcribe" Tag="transcribe" />
                        <ComboBoxItem Content="Translate to English" Tag="translate" />
                    </ComboBox>

                    <Label Content="Execution provider (Whisper + VAD)" Margin="0,8,0,0" />
                    <ComboBox x:Name="cbProvider" Width="200" HorizontalAlignment="Left" SelectedIndex="0">
                        <ComboBoxItem Content="Auto" Tag="auto" />
                        <ComboBoxItem Content="CPU" Tag="cpu" />
                        <ComboBoxItem Content="CUDA (NVIDIA)" Tag="cuda" />
                    </ComboBox>

                    <CheckBox x:Name="cbWriteSrt" Content="Write .srt side-car file" Margin="0,12,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBox x:Name="edSrtFile" Width="300" />
                        <Button x:Name="btSelectSrt" Content="..." Margin="10,0,0,0" Width="40" Click="btSelectSrt_Click"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="10,0,0,10">
            <Button x:Name="btStart" Content="Start" Width="120" Height="30" Click="btStart_Click"/>
            <Button x:Name="btStop" Content="Stop" Width="120" Height="30" Margin="10,0,0,0" IsEnabled="False" Click="btStop_Click"/>
        </StackPanel>
    </Grid>
</Window>
