<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:WPF="clr-namespace:VisioForge.Core.UI.WPF;assembly=VisioForge.Core"
    x:Class="MediaBlocks_Virtual_Camera_Demo_WPF.MainWindow"
    mc:Ignorable="d"
    Title="Media Blocks SDK .Net - Virtual Camera Demo" Height="500" Width="810" Loaded="Window_Loaded" Closing="Window_Closing" Icon="visioforge_main_icon.ico">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="370" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <WPF:VideoView Grid.Column="1" x:Name="VideoView1" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="300" Margin="10,10,10,0" />

        <StackPanel Grid.Column="0" Margin="10,10,0,10">
            <!-- Registration status -->
            <GroupBox Header="Virtual Camera Registration">
                <StackPanel Orientation="Vertical" Margin="5">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="statusIndicator" Width="12" Height="12" Fill="Gray" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lbRegistrationStatus" Text="Checking..." VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button x:Name="btRegister" Content="Register Virtual Camera (Admin)" Margin="0,8,0,0" Click="btRegister_Click" Height="28"/>
                </StackPanel>
            </GroupBox>

            <!-- Video source -->
            <Label Content="Video input device" Margin="0,8,0,0"/>
            <ComboBox x:Name="cbVideoInput" Width="340" HorizontalAlignment="Left"/>

            <!-- Audio source -->
            <Label Content="Audio input device" Margin="0,4,0,0"/>
            <ComboBox x:Name="cbAudioInput" Width="340" HorizontalAlignment="Left"/>

            <!-- Virtual camera settings -->
            <GroupBox Header="Virtual Camera Settings" Margin="0,8,0,0">
                <StackPanel Orientation="Vertical" Margin="5">
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Width" Width="50"/>
                        <TextBox x:Name="edWidth" Text="1280" Width="60"/>
                        <Label Content="Height" Width="50" Margin="10,0,0,0"/>
                        <TextBox x:Name="edHeight" Text="720" Width="60"/>
                        <Label Content="FPS" Width="40" Margin="10,0,0,0"/>
                        <TextBox x:Name="edFrameRate" Text="30" Width="40"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Log -->
            <Label Content="Log" Margin="0,4,0,0"/>
            <TextBox x:Name="mmLog" Height="100" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" Width="340" HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- Controls -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,320,0,0">
            <Button x:Name="btStart" Content="Start" Width="80" Height="28" Click="btStart_Click"/>
            <Button x:Name="btStop" Content="Stop" Width="80" Height="28" Margin="10,0,0,0" Click="btStop_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
