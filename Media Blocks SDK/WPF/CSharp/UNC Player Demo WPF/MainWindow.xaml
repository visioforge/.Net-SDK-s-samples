<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MediaBlocks_UNC_Player_Demo_WPF"
        xmlns:WPF="clr-namespace:VisioForge.Core.UI.WPF;assembly=VisioForge.Core" x:Class="MediaBlocks_UNC_Player_Demo_WPF.MainWindow"
        mc:Ignorable="d"
        Title="Media Blocks SDK .Net - UNC File Player Demo" Height="500" Width="700" Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid>
        <!-- UNC Path -->
        <Label Content="UNC path" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="edFilename" Margin="10,36,285,0" TextWrapping="Wrap" Text="\\localhost\SambaTest\video.avi" VerticalAlignment="Top"/>

        <!-- Credentials -->
        <Label Content="Username" HorizontalAlignment="Left" Margin="10,60,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="edUsername" Margin="80,63,285,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top"/>

        <Label Content="Password" HorizontalAlignment="Left" Margin="10,86,0,0" VerticalAlignment="Top"/>
        <PasswordBox x:Name="edPassword" Margin="80,89,285,0" VerticalAlignment="Top"/>

        <Label Content="Domain" HorizontalAlignment="Left" Margin="10,112,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="edDomain" Margin="80,115,285,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top"/>

        <!-- VideoView -->
        <WPF:VideoView x:Name="VideoView1" Margin="10,145,260,76"/>

        <!-- Debug and Log (Right Panel) -->
        <CheckBox x:Name="cbDebugMode" Content="Debug mode" HorizontalAlignment="Right" Margin="0,11,27,0" VerticalAlignment="Top"/>
        <Label Content="Log" HorizontalAlignment="Right" Margin="0,5,217,0" VerticalAlignment="Top"/>
        <TextBox x:Name="edLog" HorizontalAlignment="Right" Margin="0,35,27,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="220" Height="98" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>

        <!-- Audio Output -->
        <TextBlock HorizontalAlignment="Right" Margin="0,143,172,0" TextWrapping="Wrap" Text="Output device" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbAudioOutput" HorizontalAlignment="Right" Margin="0,159,27,0" VerticalAlignment="Top" Width="220"/>

        <!-- Volume -->
        <TextBlock HorizontalAlignment="Right" Margin="0,193,207,0" TextWrapping="Wrap" Text="Volume" VerticalAlignment="Top"/>
        <Slider x:Name="tbVolume" HorizontalAlignment="Right" Margin="0,206,27,0" VerticalAlignment="Top" Width="220" Maximum="100" Value="80" ValueChanged="tbVolume_ValueChanged"/>

        <!-- Timeline -->
        <Slider x:Name="tbTimeline" HorizontalAlignment="Left" Margin="10,0,0,53" VerticalAlignment="Bottom" Width="300" ValueChanged="tbTimeline_ValueChanged"/>
        <TextBlock x:Name="lbTime" HorizontalAlignment="Left" Margin="315,0,0,55" TextWrapping="Wrap" Text="00:00:00 / 00:00:00" VerticalAlignment="Bottom"/>

        <!-- Playback Controls -->
        <Button x:Name="btStart" Content="Start" HorizontalAlignment="Left" Margin="10,0,0,27" VerticalAlignment="Bottom" Width="53" Click="btStart_Click"/>
        <Button x:Name="btResume" Content="Resume" HorizontalAlignment="Left" Margin="68,0,0,27" VerticalAlignment="Bottom" Width="53" Click="btResume_Click"/>
        <Button x:Name="btPause" Content="Pause" HorizontalAlignment="Left" Margin="126,0,0,27" VerticalAlignment="Bottom" Width="53" Click="btPause_Click"/>
        <Button x:Name="btStop" Content="Stop" HorizontalAlignment="Left" Margin="184,0,0,27" VerticalAlignment="Bottom" Width="53" Click="btStop_Click"/>
    </Grid>
</Window>
