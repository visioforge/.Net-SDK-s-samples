<Window x:Class="TS_Analyzer_Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TS_Analyzer_Demo"
        mc:Ignorable="d"
        Title="Media Blocks SDK .Net - TS Analyzer Demo" Height="640" Width="980"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,8">
            <TextBlock DockPanel.Dock="Left" Text="Source:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button x:Name="btnBrowse" DockPanel.Dock="Right" Content="Browse..." Width="80" Margin="8,0,0,0" Click="btnBrowse_Click"/>
            <TextBox x:Name="edSource" VerticalAlignment="Center"
                     ToolTip="A .ts/.m2ts file path, or udp://239.0.0.1:1234, or srt://host:port. Use Browse... to pick a file."/>
        </DockPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="btnAnalyze" Content="Analyze" Width="100" Click="btnAnalyze_Click"/>
            <Button x:Name="btnStop" Content="Stop" Width="100" Margin="8,0,0,0" IsEnabled="False" Click="btnStop_Click"/>
        </StackPanel>

        <DataGrid x:Name="gridPids" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="70"/>
                <DataGridTextColumn Header="Program" Binding="{Binding Program}" Width="70"/>
                <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="80"/>
                <DataGridTextColumn Header="Type" Binding="{Binding StreamType}" Width="60"/>
                <DataGridTextColumn Header="Codec" Binding="{Binding Codec}" Width="*"/>
                <DataGridTextColumn Header="Bitrate (kbps)" Binding="{Binding Bitrate}" Width="110"/>
                <DataGridTextColumn Header="Peak (kbps)" Binding="{Binding PeakBitrate}" Width="100"/>
                <DataGridTextColumn Header="Lang" Binding="{Binding Language}" Width="60"/>
                <DataGridTextColumn Header="Packets" Binding="{Binding Packets}" Width="90"/>
                <DataGridTextColumn Header="CC errors" Binding="{Binding CcErrors}" Width="80"/>
                <DataGridCheckBoxColumn Header="PCR" Binding="{Binding IsPcr}" Width="50"/>
                <DataGridCheckBoxColumn Header="Scrambled" Binding="{Binding IsScrambled}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <Expander x:Name="expTr101290" Grid.Row="3" Margin="0,8,0,0" Header="TR 101 290" IsExpanded="True">
            <TextBlock x:Name="lblTr101290" TextWrapping="Wrap" Text="TR 101 290: not evaluated."/>
        </Expander>

        <TextBlock x:Name="lblSummary" Grid.Row="4" Margin="0,8,0,0" TextWrapping="Wrap"
                   Text="Idle."/>
    </Grid>
</Window>
