<Window x:Class="Background_Removal_Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Background_Removal_Demo" xmlns:wpf="clr-namespace:VisioForge.Core.UI.WPF;assembly=VisioForge.Core"
        mc:Ignorable="d"
        Title="Media Blocks SDK .Net - Background Removal Demo" Height="560" Width="900" Loaded="Window_Loaded" Closing="Window_Closing" Icon="visioforge_main_icon.ico">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <wpf:VideoView Grid.Column="1" x:Name="VideoView1" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="380" Margin="10,10,10,0" Width="450"/>

        <StackPanel Grid.Column="1" Orientation="Vertical" Margin="10,400,10,10" VerticalAlignment="Bottom">
            <Label Content="Log" />
            <TextBox x:Name="mmLog" Height="100" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" AcceptsReturn="True"/>
        </StackPanel>

        <TabControl Grid.Column="0" Margin="10,10,0,50" VerticalAlignment="Stretch">
            <TabItem Header="Source">
                <StackPanel Orientation="Vertical" Margin="10,10,0,0">
                    <RadioButton Content="Webcam" x:Name="rbWebcam" IsChecked="True" Checked="rbSource_Checked" />
                    <RadioButton Content="Video file" x:Name="rbFile" Margin="0,5,0,0" Checked="rbSource_Checked" />
                    <RadioButton Content="RTSP / IP camera" x:Name="rbRTSP" Margin="0,5,0,0" Checked="rbSource_Checked" />

                    <StackPanel x:Name="pnlWebcam" Orientation="Vertical" Margin="0,10,0,0">
                        <Label Content="Video input device" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <ComboBox x:Name="cbVideoInput" HorizontalAlignment="Left" VerticalAlignment="Top" Width="380" SelectionChanged="cbVideoInput_SelectionChanged"/>
                        <Label Content="Video format and frame rate" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="cbVideoFormat" Width="290" SelectionChanged="cbVideoFormat_SelectionChanged"/>
                            <ComboBox x:Name="cbVideoFrameRate" Margin="10,0,0,0" Width="55"/>
                            <Label Content="fps" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="pnlFile" Orientation="Vertical" Margin="0,10,0,0" Visibility="Collapsed">
                        <Label Content="Video file" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="edVideoFile" Width="320" VerticalContentAlignment="Center"/>
                            <Button x:Name="btSelectVideoFile" Content="..." Width="40" Margin="10,0,0,0" Click="btSelectVideoFile_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="pnlRTSP" Orientation="Vertical" Margin="0,10,0,0" Visibility="Collapsed">
                        <Label Content="RTSP URL" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <TextBox x:Name="edRTSPURL" Width="380" VerticalContentAlignment="Center" Text="rtsp://"/>
                        <Label Content="Login" HorizontalAlignment="Left" Margin="0,5,0,0"/>
                        <TextBox x:Name="edRTSPLogin" Width="380" VerticalContentAlignment="Center"/>
                        <Label Content="Password" HorizontalAlignment="Left" Margin="0,5,0,0"/>
                        <PasswordBox x:Name="edRTSPPassword" Width="380"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="Background">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Orientation="Vertical" Margin="10,10,0,10">
                        <Label Content="Matting model" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <ComboBox x:Name="cbModel" Width="380" HorizontalAlignment="Left" SelectionChanged="cbModel_SelectionChanged"/>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="btDownloadModel" Content="Download" Width="80" Click="btDownloadModel_Click" Visibility="Collapsed"/>
                            <Button x:Name="btSelectModel" Content="Browse..." Width="80" Click="btSelectModel_Click" Visibility="Collapsed"/>
                            <TextBox x:Name="edModelFile" Width="290" VerticalContentAlignment="Center" Margin="5,0,0,0"/>
                        </StackPanel>

                        <Separator Margin="0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <Label Content="Replacement" Width="120"/>
                            <ComboBox x:Name="cbMode" Width="200" SelectedIndex="0" SelectionChanged="cbMode_SelectionChanged">
                                <ComboBoxItem Content="Blur background" Tag="blur"/>
                                <ComboBoxItem Content="Solid color" Tag="color"/>
                                <ComboBoxItem Content="Image" Tag="image"/>
                                <ComboBoxItem Content="Transparent (alpha)" Tag="transparent"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel x:Name="pnlBlur" Orientation="Horizontal" Margin="0,8,0,0">
                            <Label Content="Blur radius" Width="120"/>
                            <Slider x:Name="slBlur" Minimum="1" Maximum="40" Value="15" Width="160" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="slBlur_ValueChanged"/>
                            <Label Content="{Binding Value, ElementName=slBlur}" Width="40"/>
                        </StackPanel>

                        <StackPanel x:Name="pnlColor" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                            <Label Content="Color (#RRGGBB)" Width="120"/>
                            <TextBox x:Name="edColor" Text="#00B140" Width="100" VerticalContentAlignment="Center" TextChanged="edColor_TextChanged"/>
                        </StackPanel>

                        <StackPanel x:Name="pnlImage" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                            <Label Content="Background" Width="120"/>
                            <TextBox x:Name="edImageFile" Width="220" VerticalContentAlignment="Center"/>
                            <Button x:Name="btSelectImage" Content="..." Width="40" Margin="5,0,0,0" Click="btSelectImage_Click"/>
                        </StackPanel>

                        <Separator Margin="0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <Label Content="Frames to skip" Width="120" ToolTip="Run the model every N+1 frames. The background is still composited on every frame."/>
                            <TextBox x:Name="edFramesToSkip" Text="0" Width="60" VerticalContentAlignment="Center" TextChanged="edFramesToSkip_TextChanged"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Label Content="Edge hardening" Width="120" ToolTip="0..0.5. 0 keeps the raw soft matte; higher hardens the matte edge."/>
                            <TextBox x:Name="edThreshold" Text="0" Width="60" VerticalContentAlignment="Center" TextChanged="edThreshold_TextChanged"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Label Content="Edge feather" Width="120" ToolTip="Softens the matte edge (matte pixels). 0 = off. Opposite of edge hardening."/>
                            <Slider x:Name="slFeather" Minimum="0" Maximum="15" Value="0" Width="160" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="slFeather_ValueChanged"/>
                            <Label Content="{Binding Value, ElementName=slFeather}" Width="40"/>
                        </StackPanel>

                        <Separator Margin="0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <Label Content="Execution provider" Width="120"/>
                            <ComboBox x:Name="cbProvider" Width="200" SelectedIndex="0">
                                <ComboBoxItem Content="Auto (best available)" Tag="auto"/>
                                <ComboBoxItem Content="GPU (DirectML)" Tag="directml"/>
                                <ComboBoxItem Content="CPU" Tag="cpu"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Label Content="Input size" Width="120" ToolTip="Square model input for the matting model (e.g. MODNet / PP-MattingV2). Larger = sharper edges, slower."/>
                            <TextBox x:Name="edInputSize" Text="512" Width="60" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="10,0,0,12">
            <Button x:Name="btStart" Content="Start" Width="120" Height="30" Click="btStart_Click"/>
            <Button x:Name="btStop" Content="Stop" Width="120" Height="30" Margin="10,0,0,0" Click="btStop_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
