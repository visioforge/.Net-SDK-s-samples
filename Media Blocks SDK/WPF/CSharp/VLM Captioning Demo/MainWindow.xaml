<Window x:Class="VLM_Captioning_Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VLM_Captioning_Demo" xmlns:wpf="clr-namespace:VisioForge.Core.UI.WPF;assembly=VisioForge.Core"
        mc:Ignorable="d"
        Title="Media Blocks SDK .Net - VLM Captioning Demo" Height="760" Width="1180" Loaded="Window_Loaded" Closing="Window_Closing" Icon="visioforge_main_icon.ico">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#F0F4F8" Padding="12,8">
            <TextBlock TextWrapping="Wrap" Foreground="#333"
                       Text="Vision-Language captioning with Florence-2. For each sampled frame the model runs the selected task — caption, detailed caption, object detection, dense region caption, OCR, or phrase grounding — over a webcam or video file. Results appear in the table below."/>
        </Border>
        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="480" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="230" />
        </Grid.RowDefinitions>

        <wpf:VideoView Grid.Column="1" Grid.Row="0" x:Name="VideoView1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="10,10,10,40"/>

        <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10,0,0,10">
            <Button x:Name="btStart" Content="Start" Width="70" Click="btStart_Click"/>
            <Button x:Name="btStop" Content="Stop" Width="70" Margin="10,0,0,0" Click="btStop_Click" IsEnabled="False"/>
            <TextBlock Text="00:00:00" x:Name="lbTime" VerticalAlignment="Center" Margin="15,0,0,0"/>
            <TextBlock x:Name="lbStatus" VerticalAlignment="Center" Margin="20,0,0,0" Foreground="DarkSlateGray" Text="Provider: -"/>
        </StackPanel>

        <TabControl Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Margin="10,10,0,10" VerticalAlignment="Stretch">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="8,2"/>
                    <Setter Property="FontSize" Value="11"/>
                </Style>
            </TabControl.Resources>
            <TabItem Header="Source">
                <StackPanel Orientation="Vertical" Margin="10,10,0,0">
                    <RadioButton Content="Webcam" x:Name="rbWebcam" IsChecked="True" Checked="rbSource_Checked" />
                    <RadioButton Content="Video file" x:Name="rbFile" Margin="0,5,0,0" Checked="rbSource_Checked" />

                    <StackPanel x:Name="pnlWebcam" Orientation="Vertical" Margin="0,10,0,0">
                        <Label Content="Video input device"/>
                        <ComboBox x:Name="cbVideoInput" Width="440" HorizontalAlignment="Left" SelectionChanged="cbVideoInput_SelectionChanged"/>
                        <Label Content="Video format and frame rate"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="cbVideoFormat" Width="350" SelectionChanged="cbVideoFormat_SelectionChanged"/>
                            <ComboBox x:Name="cbVideoFrameRate" Margin="10,0,0,0" Width="55"/>
                            <Label Content="fps" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="pnlFile" Orientation="Vertical" Margin="0,10,0,0" Visibility="Collapsed">
                        <Label Content="Video file"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="edVideoFile" Width="390" VerticalContentAlignment="Center"/>
                            <Button x:Name="btSelectVideoFile" Content="..." Width="40" Margin="10,0,0,0" Click="btSelectVideoFile_Click"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="Model">
                <StackPanel Orientation="Vertical" Margin="10,10,0,0">
                    <Label Content="Florence-2 model folder"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="edModelFolder" Width="360" VerticalContentAlignment="Center"/>
                        <Button Content="..." Width="40" Margin="6,0,0,0" Click="btSelectFolder_Click"/>
                    </StackPanel>

                    <Button x:Name="btDownloadModels" Content="Download model files" Width="200" HorizontalAlignment="Left" Margin="0,12,0,0" Click="btDownloadModels_Click"/>

                    <StackPanel x:Name="pnlDownload" Orientation="Vertical" Margin="0,10,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="lbDownloadStatus" Width="440" HorizontalAlignment="Left" TextTrimming="CharacterEllipsis"/>
                        <ProgressBar x:Name="pbDownload" Width="440" Height="18" HorizontalAlignment="Left" Margin="0,4,0,0" Minimum="0" Maximum="100"/>
                    </StackPanel>

                    <TextBlock Width="440" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="Gray"
                               Text="Florence-2 base (4 ONNX models + tokenizer files). Weights are NOT shipped with the SDK. They are cached under %USERPROFILE%\VisioForge\models\vlm. Generation is greedy (no beam search) and runs on a background worker (CPU)."/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Task">
                <StackPanel Orientation="Vertical" Margin="10,10,0,0">
                    <Label Content="Task"/>
                    <ComboBox x:Name="cbTask" Width="300" HorizontalAlignment="Left" SelectionChanged="cbTask_SelectionChanged"/>

                    <Label Content="Text input (Phrase grounding caption)" Margin="0,8,0,0"/>
                    <TextBox x:Name="edTextInput" Width="440" HorizontalAlignment="Left" VerticalContentAlignment="Center" IsEnabled="False" TextChanged="edTextInput_TextChanged"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Label Content="Processing interval (s)" Width="200"/>
                        <TextBox x:Name="edInterval" Text="1.0" Width="60" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Label Content="Max new tokens" Width="200"/>
                        <TextBox x:Name="edMaxTokens" Text="256" Width="60" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <CheckBox x:Name="cbDrawResults" Content="Draw results on video" IsChecked="True" Margin="0,10,0,0"/>

                    <TextBlock Width="440" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="Gray"
                               Text="Task and text input can be changed while the pipeline runs; the change takes effect on the next inference."/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Log">
                <TextBox x:Name="mmLog" Margin="10" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" IsReadOnly="True"/>
            </TabItem>
        </TabControl>

        <DataGrid Grid.Column="1" Grid.Row="1" x:Name="dgResults" Margin="10,0,10,10" AutoGenerateColumns="False"
                  IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="90"/>
                <DataGridTextColumn Header="Task" Binding="{Binding Task}" Width="150"/>
                <DataGridTextColumn Header="Text" Binding="{Binding Text}" Width="*"/>
                <DataGridTextColumn Header="ms" Binding="{Binding InferenceTimeMs}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>
        </Grid>
    </DockPanel>
</Window>
