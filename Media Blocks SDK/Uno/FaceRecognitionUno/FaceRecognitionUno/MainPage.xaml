<Page x:Class="FaceRecognitionUno.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vf="using:VisioForge.Core.UI.Uno"
      xmlns:toolkit="using:Uno.UI.Toolkit"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <vf:VideoView x:Name="videoView"
                      Grid.Row="0"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" />

        <StackPanel x:Name="pnMain" Grid.Row="1" Orientation="Vertical" Background="#1e1e1e" Padding="8" Spacing="4"
                    toolkit:VisibleBoundsPadding.PaddingMask="Bottom">

            <!-- Status -->
            <TextBlock x:Name="lbModels" Text="Models: not downloaded" Foreground="White" FontSize="12" />
            <TextBlock x:Name="lbGallery" Text="Gallery: 0 identities" Foreground="White" FontSize="12" />
            <TextBlock x:Name="lbStatus" Text="Idle" Foreground="#80FF80" FontSize="12" />
            <TextBlock x:Name="lbEmbHint" Text="" Foreground="#FFC080" FontSize="11" TextWrapping="Wrap" />

            <ProgressBar x:Name="pbDownload" Minimum="0" Maximum="100" Visibility="Collapsed" />

            <!-- Models / camera / embedder. Equal-width columns so the row fits a narrow phone
                 screen (fixed MinWidths overflowed and clipped DOWNLOAD MODELS on the right). -->
            <Grid ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="btCamera" Grid.Column="0" Content="CAMERA" HorizontalAlignment="Stretch" Click="btCamera_Clicked" />
                <Button x:Name="btEmbModel" Grid.Column="1" Content="SFace (128-D)" HorizontalAlignment="Stretch" Click="btEmbModel_Clicked" />
                <Button x:Name="btDownloadModels" Grid.Column="2" Content="DOWNLOAD MODELS" HorizontalAlignment="Stretch" Click="btDownloadModels_Clicked" />
            </Grid>

            <!-- Enrollment. The name box stretches and the button stays auto-width so the row
                 fits a narrow phone instead of forcing a fixed 200px field. -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                <TextBox x:Name="edName" Grid.Column="0" PlaceholderText="Person name" HorizontalAlignment="Stretch" />
                <Button x:Name="btEnroll" Grid.Column="1" Content="ENROLL PHOTO" Click="btEnroll_Clicked" />
            </Grid>

            <!-- Gallery + recognition options -->
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Button x:Name="btSaveGallery" Content="SAVE GALLERY" Click="btSaveGallery_Clicked" />
                <Button x:Name="btLoadGallery" Content="LOAD GALLERY" Click="btLoadGallery_Clicked" />
                <CheckBox x:Name="cbDrawResults" Content="Draw results" IsChecked="True" Foreground="White" />
            </StackPanel>

            <Button x:Name="btStartStop" Content="START" HorizontalAlignment="Stretch" Background="#4CAF50" Foreground="White" Click="btStartStop_Clicked" />

        </StackPanel>
    </Grid>
</Page>
