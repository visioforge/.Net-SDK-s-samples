<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HLS_Player_MB_MAUI.MainPage"
             xmlns:my="clr-namespace:VisioForge.Core.UI.MAUI;assembly=VisioForge.Core.UI.MAUI"
             Title="HLS Stream Player">

    <Grid>
        <Grid RowSpacing="0" RowDefinitions="Auto,*,Auto,Auto">
            
            <!-- HLS URL Input Section -->
            <StackLayout Grid.Row="0" Padding="10" BackgroundColor="#2e2e2e">
                <Label Text="HLS Stream URL:" TextColor="White" FontSize="16" />
                <Entry x:Name="txtHLSUrl" 
                       Text="https://test-streams.mux.dev/x36xhzz/x36xhzz.m3u8"
                       TextColor="White"
                       BackgroundColor="#1e1e1e"
                       Placeholder="Enter HLS stream URL..."
                       PlaceholderColor="Gray"
                       Margin="0,5,0,5" />
                
                <!-- Predefined HLS Streams -->
                <Label Text="Sample Streams:" TextColor="Gray" FontSize="14" Margin="0,10,0,5" />
                <Picker x:Name="pickerSampleStreams" 
                        TextColor="White"
                        BackgroundColor="#1e1e1e"
                        SelectedIndexChanged="pickerSampleStreams_SelectedIndexChanged">
                    <Picker.Items>
                        <x:String>Mux Test Stream</x:String>
                        <x:String>Sintel Movie</x:String>
                        <x:String>Tears of Steel</x:String>
                        <x:String>Apple Sample Stream</x:String>
                    </Picker.Items>
                </Picker>
            </StackLayout>

            <!-- Video Player -->
            <my:VideoView Grid.Row="1"               
                HorizontalOptions="FillAndExpand"
                VerticalOptions="FillAndExpand"
                x:Name="videoView"
                Background="Black"/>

            <!-- Stream Info -->
            <StackLayout Grid.Row="2" Padding="10" BackgroundColor="#2e2e2e">
                <Label x:Name="lblStreamInfo" 
                       Text="Stream Status: Not Connected" 
                       TextColor="White" 
                       FontSize="14" />
                <Label x:Name="lblVideoInfo" 
                       Text="" 
                       TextColor="Gray" 
                       FontSize="12" />
                <Label x:Name="lblAudioInfo" 
                       Text="" 
                       TextColor="Gray" 
                       FontSize="12" />
            </StackLayout>

            <!-- Player Controls — vertically stacked groups so nothing overlaps on narrow phones
                 while still laying out cleanly on wide desktop windows. -->
            <StackLayout Grid.Row="3" x:Name="pnMain" Orientation="Vertical" HorizontalOptions="Fill" BackgroundColor="#1e1e1e" Padding="10" Spacing="8">

                <!-- Seek Bar -->
                <Slider
                    x:Name="slSeeking"
                    HorizontalOptions="Fill"
                    VerticalOptions="Center"
                    ValueChanged="slSeeking_ValueChanged" />

                <!-- Time Display + transient status -->
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                    <Label
                        Grid.Column="0"
                        Text="00:00:00"
                        x:Name="lbPosition"
                        VerticalOptions="Center"
                        TextColor="White" />

                    <Label
                        Grid.Column="1"
                        Text=""
                        x:Name="lbStatus"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        TextColor="Yellow"
                        FontSize="12"
                        LineBreakMode="TailTruncation" />

                    <Label
                        Grid.Column="2"
                        Text="00:00:00"
                        x:Name="lbDuration"
                        VerticalOptions="Center"
                        TextColor="White" />
                </Grid>

                <!-- Connection status -->
                <StackLayout Orientation="Horizontal" Spacing="8" VerticalOptions="Center">
                    <BoxView x:Name="connectionIndicator"
                             WidthRequest="14"
                             HeightRequest="14"
                             CornerRadius="7"
                             Color="Red"
                             VerticalOptions="Center" />
                    <Label Text="Disconnected"
                           x:Name="lblConnectionStatus"
                           TextColor="White"
                           VerticalOptions="Center" />
                </StackLayout>

                <!-- Play / Stop: each fills half the width, so they never overlap on any screen size -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button
                        Grid.Column="0"
                        x:Name="btPlay"
                        Text="PLAY"
                        HorizontalOptions="Fill"
                        Clicked="btPlay_Clicked" />

                    <Button
                        Grid.Column="1"
                        x:Name="btStop"
                        Text="STOP"
                        IsEnabled="False"
                        HorizontalOptions="Fill"
                        Clicked="btStop_Clicked" />
                </Grid>

                <!-- Volume: label + slider that fills the remaining width -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Label
                        Grid.Column="0"
                        Text="Volume"
                        TextColor="White"
                        VerticalOptions="Center" />

                    <Slider
                        Grid.Column="1"
                        x:Name="slVolume"
                        HorizontalOptions="Fill"
                        Minimum="0"
                        Maximum="100"
                        Value="50"
                        VerticalOptions="Center"
                        ValueChanged="slVolume_ValueChanged" />
                </Grid>
            </StackLayout>
        </Grid>
    </Grid>
</ContentPage>