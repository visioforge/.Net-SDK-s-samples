<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenVocabularyDetectionMB.MainPage"
             xmlns:my="clr-namespace:VisioForge.Core.UI.MAUI;assembly=VisioForge.Core.UI.MAUI">

    <!-- Video on top, controls below — separate Grid rows so the panel never overlaps the video. -->
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <my:VideoView
                Grid.Row="0"
                x:Name="videoView"
                HorizontalOptions="Fill"
                VerticalOptions="Fill" />

        <StackLayout Grid.Row="1" x:Name="pnMain" Orientation="Vertical" HorizontalOptions="Fill" Background="#1e1e1e" Padding="8" Spacing="6">

            <!-- Model selection row (OWLv2 / Grounding DINO) -->
            <StackLayout Orientation="Horizontal" Spacing="8">
                <Picker x:Name="pkModel" Title="Model" TextColor="White" TitleColor="#888" HorizontalOptions="FillAndExpand" SelectedIndexChanged="pkModel_SelectedIndexChanged" />
                <Button x:Name="btDownloadModel" Text="DOWNLOAD" Clicked="btDownloadModel_Clicked" IsVisible="False" />
            </StackLayout>
            <Label x:Name="lbModelPath" Text="" FontSize="10" TextColor="#aaa" LineBreakMode="TailTruncation" />
            <ProgressBar x:Name="pbDownload" Progress="0" ProgressColor="#4CAF50" IsVisible="False" />

            <!-- Prompt row: comma-separated free-text classes, applied live via SetPrompts -->
            <StackLayout Orientation="Horizontal" Spacing="8">
                <Entry x:Name="enPrompts" Text="a person, a car" Placeholder="a person, a car, a dog" TextColor="White" PlaceholderColor="#888" HorizontalOptions="FillAndExpand" />
                <Button x:Name="btApplyPrompts" Text="APPLY" Clicked="btApplyPrompts_Clicked" />
            </StackLayout>

            <!-- Detections + controls row -->
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Label x:Name="lbStatus" Grid.Column="0" Text="Objects: -" VerticalOptions="Center" FontSize="14" FontAttributes="Bold" TextColor="#4CAF50" />
                <Button x:Name="btCamera" Grid.Column="1" Text="SELECT CAMERA" Clicked="btCamera_Clicked" />
                <Button x:Name="btStartStop" Grid.Column="2" Text="START" Clicked="btStartStop_Clicked" BackgroundColor="#4CAF50" />
            </Grid>
        </StackLayout>
    </Grid>

</ContentPage>
