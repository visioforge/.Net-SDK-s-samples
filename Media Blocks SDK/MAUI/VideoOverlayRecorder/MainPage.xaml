<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vf="clr-namespace:VisioForge.Core.UI.MAUI;assembly=VisioForge.Core.UI.MAUI"
             x:Class="VideoOverlayRecorderMB.MainPage"
             BackgroundColor="#1e1e1e"
             Title="Video Overlay Recorder">

    <!-- Fixed dark theme + explicit text colors so labels stay readable on both light- and dark-themed devices. -->
    <ContentPage.Resources>
        <Style TargetType="Label">
            <Setter Property="TextColor" Value="White" />
        </Style>
        <Style TargetType="Entry">
            <Setter Property="TextColor" Value="White" />
        </Style>
    </ContentPage.Resources>

    <!-- Single scrollable column so the control-heavy UI never overflows or overlaps on a narrow phone. -->
    <ScrollView>
        <VerticalStackLayout Padding="10" Spacing="10">

            <!-- File Selection -->
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Button Grid.Column="0" x:Name="btSelectFile" Text="Select Video File" Clicked="btSelectFile_Clicked" />
                <Label Grid.Column="1" x:Name="lbFilename" Text="No file selected" VerticalOptions="Center" />
            </Grid>

            <!-- Video Preview -->
            <Border Stroke="Gray" StrokeThickness="1" HeightRequest="240">
                <vf:VideoView x:Name="videoView" BackgroundColor="Black" />
            </Border>

            <!-- Playback Controls -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Button Grid.Column="0" x:Name="btPlay" Text="Play" HorizontalOptions="Fill" Clicked="btPlay_Clicked" />
                <Button Grid.Column="1" x:Name="btPause" Text="Pause" HorizontalOptions="Fill" Clicked="btPause_Clicked" />
                <Button Grid.Column="2" x:Name="btStop" Text="Stop" HorizontalOptions="Fill" Clicked="btStop_Clicked" />
            </Grid>

            <!-- Position -->
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <Label Grid.Column="0" Text="Position:" VerticalOptions="Center" />
                <Slider Grid.Column="1" x:Name="slPosition" Minimum="0" Maximum="100" VerticalOptions="Center" ValueChanged="slPosition_ValueChanged" />
                <Label Grid.Column="2" x:Name="lbTime" Text="00:00:00 / 00:00:00" FontSize="12" VerticalOptions="Center" />
            </Grid>

            <!-- Recording Controls -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button Grid.Column="0" x:Name="btStartRecording" Text="Start Recording" HorizontalOptions="Fill" BackgroundColor="Red" TextColor="White" Clicked="btStartRecording_Clicked" />
                <Button Grid.Column="1" x:Name="btStopRecording" Text="Stop Recording" HorizontalOptions="Fill" IsEnabled="False" Clicked="btStopRecording_Clicked" />
            </Grid>
            <Label x:Name="lbRecordingStatus" Text="Ready" HorizontalOptions="Center" />

            <!-- Add Overlay Controls -->
            <Label Text="Add Overlays:" FontAttributes="Bold" Margin="0,6,0,0" />
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <Button Grid.Column="0" x:Name="btAddText" Text="Add Text" Clicked="btAddText_Clicked" />
                <Entry Grid.Column="1" x:Name="edTextOverlay" Text="Hello World!" VerticalOptions="Center" />
            </Grid>
            <!-- Overlay-type buttons in an even 2-column grid: uniform width, and the wider half-column
                 fits longer labels (e.g. "Frame Counter") without truncation. -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                <Button Grid.Row="0" Grid.Column="0" x:Name="btAddImage" Text="Add Image" HorizontalOptions="Fill" Clicked="btAddImage_Clicked" />
                <Button Grid.Row="0" Grid.Column="1" x:Name="btAddRectangle" Text="Rectangle" HorizontalOptions="Fill" Clicked="btAddRectangle_Clicked" />
                <Button Grid.Row="1" Grid.Column="0" x:Name="btAddCircle" Text="Circle" HorizontalOptions="Fill" Clicked="btAddCircle_Clicked" />
                <Button Grid.Row="1" Grid.Column="1" x:Name="btAddLine" Text="Add Line" HorizontalOptions="Fill" Clicked="btAddLine_Clicked" />
                <Button Grid.Row="2" Grid.Column="0" x:Name="btAddTimestamp" Text="Timestamp" HorizontalOptions="Fill" Clicked="btAddTimestamp_Clicked" />
                <Button Grid.Row="2" Grid.Column="1" x:Name="btAddFrameCounter" Text="Frame Counter" HorizontalOptions="Fill" Clicked="btAddFrameCounter_Clicked" />
            </Grid>

            <!-- Overlay List -->
            <Label Text="Active Overlays:" FontAttributes="Bold" Margin="0,6,0,0" />
            <Border Stroke="Gray" StrokeThickness="1" HeightRequest="120">
                <ListView x:Name="lbOverlays" SelectionMode="Single" />
            </Border>
            <Button x:Name="btRemoveOverlay" Text="Remove Selected" HorizontalOptions="Fill" Clicked="btRemoveOverlay_Clicked" />

            <!-- Status and Log -->
            <Label x:Name="lbStatus" Text="Status: Ready" FontAttributes="Bold" Margin="0,6,0,0" />
            <Border Stroke="Gray" StrokeThickness="1" HeightRequest="80">
                <Editor x:Name="edLog" IsReadOnly="True" FontSize="12" BackgroundColor="LightGray" TextColor="Black" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
