<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VlmCaptioningMB.MainPage"
             xmlns:my="clr-namespace:VisioForge.Core.UI.MAUI;assembly=VisioForge.Core.UI.MAUI">

    <!-- Video on top, controls below — separate Grid rows so the panel never overlaps the video. -->
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <my:VideoView
                Grid.Row="0"
                x:Name="videoView"
                HorizontalOptions="Fill"
                VerticalOptions="Fill" />

        <StackLayout Grid.Row="1" x:Name="pnMain" Orientation="Vertical" HorizontalOptions="Fill" Background="#1e1e1e" Padding="8" Spacing="6">

            <!-- Florence-2 task selection + model download row -->
            <StackLayout Orientation="Horizontal" Spacing="8">
                <Picker x:Name="pkTask" Title="Task" TextColor="White" TitleColor="#888" HorizontalOptions="FillAndExpand" SelectedIndexChanged="pkTask_SelectedIndexChanged" />
                <Button x:Name="btDownloadModel" Text="DOWNLOAD" Clicked="btDownloadModel_Clicked" />
            </StackLayout>
            <Label x:Name="lbModelPath" Text="" FontSize="10" TextColor="#aaa" LineBreakMode="TailTruncation" />
            <ProgressBar x:Name="pbDownload" Progress="0" ProgressColor="#4CAF50" IsVisible="False" />

            <!-- Auxiliary text input — only used by the Phrase Grounding task. -->
            <Entry x:Name="enTextInput" Placeholder="Caption to ground (Phrase Grounding only)" TextColor="White" PlaceholderColor="#888" IsEnabled="False" TextChanged="enTextInput_TextChanged" />

            <!-- Latest caption / recognized text (scrollable so long captions don't push out the controls). -->
            <ScrollView x:Name="svCaption" HeightRequest="70">
                <Label x:Name="lbCaption" Text="Caption: -" FontSize="14" FontAttributes="Bold" TextColor="#4CAF50" LineBreakMode="WordWrap" />
            </ScrollView>

            <!-- Status + controls row -->
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Label x:Name="lbStatus" Grid.Column="0" Text="Idle" VerticalOptions="Center" FontSize="12" TextColor="#aaa" />
                <Button x:Name="btCamera" Grid.Column="1" Text="SELECT CAMERA" Clicked="btCamera_Clicked" />
                <Button x:Name="btStartStop" Grid.Column="2" Text="START" Clicked="btStartStop_Clicked" BackgroundColor="#4CAF50" />
            </Grid>
        </StackLayout>
    </Grid>

</ContentPage>
