<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Simple_Player_MB_MAUI.MainPage"
             xmlns:my="clr-namespace:VisioForge.Core.UI.MAUI;assembly=VisioForge.Core.UI.MAUI"
             xmlns:skins="clr-namespace:VisioForge.Core.UI.MAUI.Skins;assembly=VisioForge.Core.UI.MAUI" >

    <Grid RowSpacing="0" RowDefinitions="*,Auto">

        <my:VideoView Grid.Row="0"
            HorizontalOptions="FillAndExpand"
            VerticalOptions="FillAndExpand"
            x:Name="videoView"
            Background="Black"/>

        <VerticalStackLayout Grid.Row="1" x:Name="pnMain" Spacing="4" Background="#1e1e1e" Padding="12,8,12,12">

            <!-- Seek bar -->
            <Slider
                x:Name="slSeeking"
                HorizontalOptions="Fill"
                Margin="0,4,0,0"
                ValueChanged="slSeeking_ValueChanged" />

            <!-- Position / Duration -->
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0">
                <Label Grid.Column="0" Text="00:00:00" x:Name="lbPosition"
                    TextColor="#B0FFFFFF" FontSize="12" VerticalOptions="Center" />
                <Label Grid.Column="2" Text="00:00:00" x:Name="lbDuration"
                    TextColor="#B0FFFFFF" FontSize="12" VerticalOptions="Center" />
            </Grid>

            <!-- Playback controls -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8" Margin="0,4,0,0">
                <Button Grid.Column="0" x:Name="btOpen" Text="OPEN" Clicked="btOpen_Clicked" />
                <Button Grid.Column="1" x:Name="btGallery" Text="GALLERY" Clicked="btGallery_Clicked" />
                <Button Grid.Column="2" x:Name="btPlayPause" Text="PLAY" Clicked="btPlayPause_Clicked" />
                <Button Grid.Column="3" x:Name="btStop" Text="STOP" Clicked="btStop_Clicked" />
            </Grid>

            <!-- Volume + Speed -->
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Margin="0,4,0,0">
                <Label Grid.Column="0" Text="Vol" TextColor="White" FontSize="12" VerticalOptions="Center" />
                <Slider Grid.Column="1" x:Name="slVolume"
                    Minimum="0" Maximum="100" Value="25"
                    VerticalOptions="Center"
                    ValueChanged="slVolume_ValueChanged" />
                <Button Grid.Column="2" x:Name="btSpeed" Text="1X" Clicked="btSpeed_Clicked"
                    WidthRequest="56" Padding="4,0" />
            </Grid>

        </VerticalStackLayout>
    </Grid>
</ContentPage>
